{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "extends": ["./node_modules/@mrmartineau/kit/src/biome/biome.json"],
  "overrides": [
    {
      "includes": ["**/*.svelte", "**/*.astro", "**/*.vue"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          },
          "style": {
            "useConst": "off",
            "useImportType": "off"
          }
        }
      }
    }
  ]
}
