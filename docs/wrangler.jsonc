{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "zui",
	"compatibility_date": "2026-01-20",
	"observability": {
		"enabled": true
	},
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	}
}