---
import { ClientRouter } from 'astro:transitions'
import '@mrmartineau/zui/css'
import '../index.css'
import DarkModeSwitcher from '../components/DarkModeSwitcher.astro'
import MiniThemeSwitcher from '../components/MiniThemeSwitcher.astro'
import Sidebar from '../components/Sidebar.astro'
import TableOfContents from '../components/TableOfContents.astro'
import ThemeSwitcher from '../components/ThemeSwitcher.astro'

interface Props {
  title: string
  description?: string
}

// @ts-expect-error ignore
const { title, description } = (Astro.props.frontmatter ?? Astro.props) as Props
const currentPath = Astro.url.pathname

const indexPages = import.meta.glob('../pages/*/index.mdx', { eager: true })
const footerSections = Object.entries(indexPages)
  .map(([path, mod]) => {
    const fm = (
      mod as { frontmatter: { title: string; sectionOrder?: number } }
    ).frontmatter
    const key = path.match(/\/pages\/([^/]+)\//)?.[1] ?? ''
    return {
      href: `/${key}`,
      label: key.charAt(0).toUpperCase() + key.slice(1),
      sectionOrder: fm.sectionOrder ?? Infinity,
    }
  })
  .sort(
    (a, b) => a.sectionOrder - b.sectionOrder || a.label.localeCompare(b.label),
  )
---

<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ZUI — {title}</title>
    <meta name="description" content="A CSS-first UI library with optional React, Astro, Solid, Svelte, and Vue components." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="apple-touch-icon-precomposed"
      sizes="500x500"
      href="/images/favicon/icon@1x.png"
    />
    <link rel="author" href="Zander Martineau" />
    <meta name="author" content="Zander Martineau">
    <meta name="og:type" content="website" />
    <meta name="og:url" content={Astro.url} />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.2/src/regular/style.css"
    />
    <link
      rel="stylesheet"
      type="text/css"
      href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.2/src/duotone/style.css"
    />
    <script is:inline>(function(){var s=localStorage.getItem('zui-color-scheme');if(s==='dark')document.documentElement.classList.add('zui-dark');else if(s==='light')document.documentElement.classList.add('zui-light');})()</script>
    <ClientRouter />

  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-logo">ZUI</a>
      <div class="site-header-end">
        <a
          href="https://github.com/mrmartineau/zui"
          class="zui-button zui-button-variant-ghost"
          aria-label="View on GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="ph ph-github-logo"></i> Repo
        </a>
        <a
          href="https://npmx.dev/package/@mrmartineau/zui"
          aria-label="View on npmx"
          target="_blank"
          rel="noopener noreferrer"
          class="zui-button zui-button-variant-ghost"
        ><i class="ph ph-package"></i></a>
        <MiniThemeSwitcher />
        <DarkModeSwitcher />
        <button
          class="mobile-menu-btn zui-button zui-button-variant-ghost"
          type="button"
          aria-label="Open navigation"
          onclick="document.getElementById('mobile-nav').showModal()"
        >
          <i class="ph ph-list"></i>
        </button>
      </div>
    </header>

    <dialog id="mobile-nav" class="mobile-nav-dialog">
      <div class="mobile-nav-header">
        <a href="/" class="site-logo">ZUI</a>
        <button
          class="zui-button zui-button-variant-ghost"
          type="button"
          aria-label="Close navigation"
          onclick="document.getElementById('mobile-nav').close()"
        >
          <i class="ph ph-x"></i>
        </button>
      </div>
      <div class="mobile-nav-body">
        <Sidebar currentPath={currentPath} />
      </div>
    </dialog>

    <div class="site-layout">
      <aside class="site-sidebar" transition:animate="none">
        <Sidebar currentPath={currentPath} />
      </aside>
      <main class="site-main docs-prose" transition:animate="fade" data-pagefind-body>
        <div class="page-header">
          <h1>{title}</h1>
          {description && <p class="page-description">{description}</p>}
        </div>
        <slot />
      </main>
      <TableOfContents />
    </div>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <p class="site-footer-credit">
          Made by <a href="https://zander.wtf">Zander Martineau</a>
        </p>
        <nav class="site-footer-nav" aria-label="Footer">
          {footerSections.map(({ label, href }) => (
            <a href={href}>{label}</a>
          ))}
          <a
            href="https://github.com/mrmartineau/zui"
            aria-label="View on GitHub"
            target="_blank"
            rel="noopener noreferrer"
          ><i class="ph ph-github-logo"></i></a>
          <a
            href="https://npmx.dev/package/@mrmartineau/zui"
            aria-label="View on GitHub"
            target="_blank"
            rel="noopener noreferrer"
          ><i class="ph ph-package"></i></a>
        </nav>
      </div>
    </footer>

    <ThemeSwitcher />
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "88182718a8c6437783661af812d8c2fc"}'></script>
  </body>
</html>

<style>
  body {
    margin: 0;
    min-height: 100dvh;
    background-color: var(--color-background);
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface);
    position: sticky;
    top: 0;
    z-index: var(--z-1);
    height:  var(--site-header-height);
  }

  .site-header-end {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .mobile-menu-btn {
    display: none;
  }

  .site-logo {
    font-size: var(--step-1);
    font-weight: 700;
    font-family: var(--font-code);
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .site-layout {
    display: grid;
    grid-template-columns: 240px 1fr 200px;
    height: stretch;
  }

  .site-sidebar {
    position: sticky;
    top:  var(--site-header-height);
    height: 100dvh;
    overflow-y: auto;
    border-right: 1px solid var(--color-border);
    padding: 0 var(--space-xs) var(--space-sm);
    background-color: var(--color-surface);
  }

  .site-main {
    padding: var(--space-lg) var(--space-xl);
    max-width: 960px;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) var(--space-md);
    background-color: var(--color-surface);
  }

  .site-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 960px;
    margin-inline: auto;
    gap: var(--space-md);
  }

  .site-footer-credit {
    font-size: var(--step--1);
    color: var(--color-text);
    opacity: 0.6;
    margin: 0;
  }

  .site-footer-credit a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: oklch(from currentColor l c h / 40%);
    text-underline-offset: 0.3ex;
    transition: text-decoration-color 0.2s var(--ease-in-out);
  }

  .site-footer-credit a:hover {
    text-decoration-color: oklch(from currentColor l c h / 80%);
  }

  .site-footer-nav {
    display: flex;
    gap: var(--space-sm);
  }

  .site-footer-nav a {
    font-size: var(--step--1);
    color: var(--color-text);
    opacity: 0.6;
    text-decoration: none;
    transition: opacity 0.2s var(--ease-in-out);
  }

  .site-footer-nav a:hover {
    opacity: 1;
  }

  /* Mobile nav dialog */
  .mobile-nav-dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background-color: var(--color-surface);
    color: var(--color-text);
    z-index: var(--z-4);
    overflow-y: auto;
  }

  .mobile-nav-dialog::backdrop {
    background-color: oklch(0 0 0 / 50%);
  }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav-body {
    padding: var(--space-sm) var(--space-md);
  }

  @media (max-width: 1024px) {
    .site-layout {
      grid-template-columns: 240px 1fr;
    }

    .site-layout > :global(.toc) {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .site-layout {
      grid-template-columns: 1fr;
    }

    .site-sidebar {
      display: none;
    }

    .site-main {
      padding: var(--space-md);
    }

    .mobile-menu-btn {
      display: inline-flex;
    }

    .site-footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<style is:global>

  :root {
    --site-header-height: 3.5rem;
    --scroll-margin: calc(var(--site-header-height) + 1rem);
  }
  .docs-prose {
    color: var(--color-text);

  }
  [id] {
    scroll-margin-top: var(--scroll-margin);
  }

  .docs-prose > * + * {
    margin-block-start: var(--flow-space, 1em);
  }

  .docs-prose :is(h1, h2, h3, blockquote) {
    --flow-space: 2rem;
  }

  .docs-prose :is(h1, h2, h3) + * {
    --flow-space: 1rem;
  }

  .page-header {
    margin-block-end: var(--space-lg);
  }

  .page-description {
    font-size: var(--step-1);
    color: color-mix(in oklch, var(--color-text) 65%, transparent);
    margin-block-start: var(--space-2xs) !important;
    line-height: var(--line-height-md);
    text-wrap: balance;
  }

  .docs-prose h1 {
    font-size: var(--step-3);
    line-height: 1.1;
    text-wrap: balance;
    font-family: var(--font-display);
    font-weight: var(--font-weight-7);
  }

  .docs-prose h2 {
    font-size: var(--step-2);
    line-height: 1.1;
    text-wrap: balance;
    font-family: var(--font-display);
    font-weight: var(--font-weight-7);
    color: var(--color-theme);
  }

  .docs-prose h3 {
    font-size: var(--step-1);
    line-height: 1.1;
    text-wrap: balance;
    font-family: var(--font-display);
    font-weight: var(--font-weight-7);
  }

  .docs-prose > p,
  .docs-prose > li {
    font-size: var(--step-0);
  }


  .docs-prose a:not(.zui-button):not(.zui-card) {
    color: var(--color-text);
    text-decoration-line: underline;
    text-decoration-color: oklch(from var(--color-text) l c h / 50%);
    text-decoration-thickness: 0.2ex;
    text-underline-offset: 0.3ex;
    border-radius: var(--radius-md);
    transition: text-decoration-color 0.2s var(--ease-in-out);
  }

  .docs-prose a:not(.zui-button):hover {
    text-decoration-color: oklch(from var(--color-text) l c h / 90%);
  }

  .docs-prose :not(pre) > code {
    font-family: var(--font-code);
    font-size: var(--step--2);
    background-color: oklch(from var(--color-background) calc(l + 0.1) c h);
    color: oklch(from var(--color-text) calc(l + 0.1) c h);
    padding: 2px 4px;
    border-radius: var(--radius-md);
    line-height: var(--line-height-xs);
  }

  .docs-prose ul,
  .docs-prose ol {
    padding-inline-start: 0;
    list-style-position: inside;
  }

  .docs-prose ul { list-style-type: disc; }
  .docs-prose ol { list-style-type: decimal; }

  .docs-prose ul ul,
  .docs-prose ol ol {
    padding-inline-start: 1rem;
  }

  .docs-prose hr {
    margin: 2em 0;
    height: 1px;
    border: 0;
    background-color: var(--color-border);
  }

  .docs-prose table {
    width: 100%;
    caption-side: bottom;
    font-variant-numeric: tabular-nums;
    table-layout: fixed;
    border-collapse: collapse;
    border: 0;
  }

  .docs-prose tr {
    border-bottom: 1px solid oklch(from currentColor l c h / 15%);
    transition: background-color 150ms ease-in-out;
  }

  .docs-prose tbody tr:hover {
    background-color: oklch(from currentColor l c h / 10%);
  }

  .docs-prose th {
    line-height: var(--line-height-xl);
    padding-inline: var(--space-2xs);
    text-align: left;
    vertical-align: middle;
    font-weight: var(--font-weight-bold);
    border-bottom: 1px solid oklch(from currentColor l c h / 15%);
  }

  .docs-prose td {
    padding: var(--space-2xs);
    vertical-align: middle;
  }
</style>
