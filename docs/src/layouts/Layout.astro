---
import { DocsLayout } from '@mrmartineau/zui-theme/astro'
import { footerSections, sidebarSections } from '../nav'
import { site } from '../site.config'

interface Props {
  title?: string
  description?: string
}

// @ts-expect-error ignore
const { title, description } = (Astro.props.frontmatter ?? Astro.props) as Props
const currentPath = Astro.url.pathname
---

<DocsLayout
  title={title}
  description={description}
  currentPath={currentPath}
  site={site}
  sections={sidebarSections}
  footerSections={footerSections}
>
  <Fragment slot="head">
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bagel+Fat+One&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet">
  </Fragment>
  <slot />
  <Fragment slot="body-end">
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "88182718a8c6437783661af812d8c2fc"}'></script>
  </Fragment>
</DocsLayout>
