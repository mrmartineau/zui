---
import {
  BaseLayout,
  buildFooterSections,
  buildSidebarSections,
} from '@mrmartineau/zui-theme/astro'
import { site } from '../site.config'

interface Props {
  title?: string
  description?: string
}

const { title, description } = Astro.props
const currentPath = Astro.url.pathname

const pages = import.meta.glob('../pages/**/*.mdx', { eager: true })
const indexPages = import.meta.glob('../pages/*/index.mdx', { eager: true })

const sections = buildSidebarSections(pages, {
  append: [
    { heading: 'Guides', items: [{ href: '/changelog', label: 'Changelog' }] },
  ],
})
const footerSections = buildFooterSections(indexPages)
---

<BaseLayout
  title={title}
  description={description}
  currentPath={currentPath}
  site={site}
  sections={sections}
  footerSections={footerSections}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bagel+Fat+One&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet">
  </Fragment>
  <main class="home-main" transition:animate="fade">
    <slot />
  </main>
  <Fragment slot="body-end">
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "88182718a8c6437783661af812d8c2fc"}'></script>
  </Fragment>
</BaseLayout>

<style>
  .home-main {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding: var(--space-lg) var(--space-xl);
  }

  @media (max-width: 767px) {
    .home-main {
      padding: var(--space-md);
    }
  }
</style>
