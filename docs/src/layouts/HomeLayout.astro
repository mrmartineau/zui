---
import { BaseLayout } from '@mrmartineau/zui-theme/astro'
import SiteTheme from '../components/SiteTheme.astro'
import SiteThemeMenu from '../components/SiteThemeMenu.astro'
import { footerSections, sidebarSections } from '../nav'
import { site } from '../site.config'

interface Props {
  title?: string
  description?: string
}

const { title, description } = Astro.props
const currentPath = Astro.url.pathname
---

<BaseLayout
  title={title}
  description={description}
  currentPath={currentPath}
  site={site}
  sections={sidebarSections}
  footerSections={footerSections}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bagel+Fat+One&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet">
    <SiteTheme />
  </Fragment>
  <SiteThemeMenu slot="theme-menu" />
  <main class="home-main" transition:animate="fade">
    <slot />
  </main>
  <Fragment slot="body-end">
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "88182718a8c6437783661af812d8c2fc"}'></script>
  </Fragment>
</BaseLayout>

<style>
  .home-main {
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding: var(--space-lg) var(--space-xl);
  }

  @media (max-width: 767px) {
    .home-main {
      padding: var(--space-md);
    }
  }
</style>
