---
import { Code } from 'astro:components'

interface Props {
  code: string
}

const { code = '' } = Astro.props
---

<div class="demo">
  <div class="demo-preview">
    <slot />
  </div>
  <Code code={code?.trim()} lang="html" themes={{
    light: 'rose-pine-dawn',
    dark: 'rose-pine'
  }} />
</div>

<style>
  .demo {
    margin-bottom: 1.5rem;
  }
  .demo-preview {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }
  .demo :global(pre) {
    margin: 0;
    border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    border: 1px solid var(--color-border);
    border-top: none;
    font-size: 0.8125rem;
    padding: 1rem;
    overflow-x: auto;
  }
</style>
