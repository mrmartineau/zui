---
interface Props {
  value?: string
  class?: string
}

const { value, class: className } = Astro.props
---

<code
  class:list={['zui-code', 'copy-code', className]}
  data-copy={value}
  tabindex="0"
  role="button"
>
  <slot />
  <i class="ph-duotone ph-copy copy-icon"></i>
  <i class="ph-duotone ph-check-circle copy-icon-success" aria-hidden="true"></i>
</code>

<script>
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement).closest<HTMLElement>('.copy-code')
    if (!el) return

    const text = el.dataset.copy || el.textContent?.replace('Copied!', '').trim() || ''
    navigator.clipboard.writeText(text)

    el.classList.add('copied')
    setTimeout(() => el.classList.remove('copied'), 1200)
  })

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return
    const el = (e.target as HTMLElement).closest<HTMLElement>('.copy-code')
    if (!el) return
    e.preventDefault()
    el.click()
  })
</script>

<style>
  .copy-code {
    cursor: pointer;
    position: relative;
    transition: opacity 0.15s ease;
    font-variant-ligatures: none;
  }

  .copy-code:hover {
    opacity: 0.8;
  }

  .copy-icon {
    display: inline-flex;
    opacity: 0;
    margin-inline-start: 0.3em;
    vertical-align: middle;
    transition: opacity 0.15s ease;
  }

  .copy-code:hover .copy-icon,
  .copy-code:focus-visible .copy-icon {
    opacity: 1;
  }

  .copy-code.copied .copy-icon {
    display: none;
  }

  .copy-icon-success {
    display: none;
    margin-inline-start: 0.3em;
    vertical-align: middle;
    color: var(--color-success, green);
  }

  .copy-code.copied .copy-icon-success {
    display: inline-flex;
  }
</style>
