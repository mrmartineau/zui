---
import ColorRow from './ColorRow.astro'

const shades = [50, 100, 200, 300, 400, 500, 600, 700, 800, 900, 950]
const colorNames = [
  'red',
  'orange',
  'amber',
  'yellow',
  'lime',
  'green',
  'emerald',
  'teal',
  'cyan',
  'sky',
  'blue',
  'indigo',
  'violet',
  'purple',
  'fuchsia',
  'pink',
  'rose',
  'slate',
  'gray',
  'zinc',
  'neutral',
  'stone',
  'taupe',
  'mauve',
  'mist',
  'olive',
]

const colors = colorNames.map((name) => ({
  name,
  shades: shades.map((shade) => ({ shade, value: `--color-${name}-${shade}` })),
}))
---

<div class="color-palette">
  <div class="color-palette__corner" aria-hidden="true"></div>

  <div class="color-palette__header" aria-hidden="true">
    {shades.map((shade) => <span>{shade}</span>)}
  </div>

  {colors.map(({ name, shades: colorShades }) => (
    <ColorRow name={name} shades={colorShades} />
  ))}

  <div class="color-palette__footer" aria-hidden="true">
    Click a swatch to copy its CSS custom property value.
  </div>
</div>

<style>
  .color-palette {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem 1rem;
  }

  @media (min-width: 640px) {
    .color-palette {
      gap: 1rem;
    }
  }

  .color-palette__corner {
    position: sticky;
    top: 3.5rem;
    z-index: 9;
    background: light-dark(white, oklch(12.9% 0.042 264.695));
  }

  .color-palette__header {
    position: sticky;
    top: 0;
    z-index: 9;
    background: var(--color-background);
    grid-column: 2;
    display: grid;
    grid-template-columns: repeat(11, 1fr);
    gap: 0.375rem;
    justify-items: center;
    font-weight: 500;
    font-size: 0.8125rem;
    padding-block: 0.5rem;
  }

  @media (min-width: 640px) {
    .color-palette__header {
      gap: 1rem;
    }
  }

  .color-palette__header span {
    transform: rotate(180deg);
    writing-mode: vertical-lr;
  }

  @media (min-width: 640px) {
    .color-palette__header span {
      transform: none;
      writing-mode: horizontal-tb;
    }
  }

  .color-palette__footer {
    grid-column: 1 / -1;
    text-align: center;
    font-style: italic;
    color: light-dark(oklch(55.1% 0.027 264.364), oklch(70.7% 0.022 261.325));
    font-size: 0.875rem;
    padding-top: 0.5rem;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.color-swatch').forEach((swatch) => {
    const btn = swatch.querySelector<HTMLButtonElement>('.color-swatch__btn');
    if (!btn) return;

    btn.addEventListener('click', async () => {
      const value = swatch.dataset.value;
      if (!value) return;

      try {
        await navigator.clipboard.writeText(value);
        swatch.classList.add('color-swatch--copied');
        const tooltip = swatch.querySelector<HTMLElement>('.color-swatch__tooltip');
        if (tooltip) {
          const original = tooltip.textContent;
          tooltip.textContent = 'Copied!';
          setTimeout(() => {
            tooltip.textContent = original;
            swatch.classList.remove('color-swatch--copied');
          }, 1200);
        }
      } catch {
        // clipboard not available
      }
    });
  });
</script>
