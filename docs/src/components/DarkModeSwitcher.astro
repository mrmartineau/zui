---

<button
  id="dark-mode-toggle"
  class="zui-button zui-button-variant-ghost"
  type="button"
  aria-label="Toggle color scheme"
  title="Toggle color scheme"
>
  <i class="ph ph-sun" id="dms-icon-sun" hidden></i>
  <i class="ph ph-moon" id="dms-icon-moon" hidden></i>
</button>

<script>
  const STORAGE_KEY = 'zui-color-scheme'

  function getScheme() {
    return localStorage.getItem(STORAGE_KEY) ?? 'system'
  }

  function isDarkActive() {
    const scheme = getScheme()
    return (
      scheme === 'dark' ||
      (scheme === 'system' &&
        window.matchMedia('(prefers-color-scheme: dark)').matches)
    )
  }

  function applyScheme(dark: boolean) {
    document.documentElement.classList.toggle('zui-dark', dark)
    document.documentElement.classList.toggle('zui-light', !dark)
    localStorage.setItem(STORAGE_KEY, dark ? 'dark' : 'light')
    window.dispatchEvent(
      new CustomEvent('zui-color-scheme-change', {
        detail: dark ? 'dark' : 'light',
      }),
    )
  }

  function updateIcon(dark: boolean) {
    const sun = document.getElementById('dms-icon-sun')
    const moon = document.getElementById('dms-icon-moon')
    if (sun) sun.hidden = !dark
    if (moon) moon.hidden = dark
  }

  function init() {
    const btn = document.getElementById('dark-mode-toggle')
    if (!btn) return

    const dark = isDarkActive()
    updateIcon(dark)

    btn.addEventListener('click', () => {
      const next = !isDarkActive()
      applyScheme(next)
      updateIcon(next)
    })

    window
      .matchMedia('(prefers-color-scheme: dark)')
      .addEventListener('change', (e) => {
        if (getScheme() === 'system') updateIcon(e.matches)
      })
  }

  document.addEventListener('astro:page-load', init)
</script>
