---
interface Props {
  src: string
  title: string
  height?: string
}

const { src, title, height = '500px' } = Astro.props
---

<div class="iframe-demo" style={`--iframe-demo-height: ${height}`}>
  <iframe
    src={src}
    title={title}
    loading="lazy"
  />
</div>

<style>
  .iframe-demo {
    margin-block: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--color-background);
  }

  .iframe-demo iframe {
    display: block;
    width: 100%;
    height: var(--iframe-demo-height, 500px);
    border: 0;
  }
</style>
