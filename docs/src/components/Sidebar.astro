---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

const guides = [
  { href: '/installation', label: 'Installation' },
  { href: '/colors', label: 'Colours' },
  { href: '/typography', label: 'Typography' },
  { href: '/theming', label: 'Theming' },
  { href: '/layers', label: 'CSS Layers' },
  { href: '/guides/react', label: 'Using with React' },
  { href: '/guides/astro', label: 'Using with Astro' },
  { href: '/guides/other-frameworks', label: 'Other UI Libraries' },
  { href: '/guides/dark-mode', label: 'Dark Mode' },
  { href: '/guides/skills', label: 'AI Agent Skills' },
  { href: '/guides/copy-source', label: 'Copy source into project' },
]

const tokens = [
  { href: '/tokens', label: 'Overview' },
  { href: '/tokens/space', label: 'Space' },
  { href: '/tokens/shadows', label: 'Shadows' },
  { href: '/tokens/radii', label: 'Border Radius' },
  { href: '/tokens/easing', label: 'Easing' },
  { href: '/tokens/animation', label: 'Animation' },
  { href: '/tokens/aspect-ratio', label: 'Aspect Ratio' },
  { href: '/tokens/size', label: 'Size' },
  { href: '/tokens/z-index', label: 'Z-Index' },
]

const components = [
  { href: '/components/badge', label: 'Badge' },
  { href: '/components/button', label: 'Button' },
  { href: '/components/card', label: 'Card' },
  { href: '/components/checkbox', label: 'Checkbox' },
  { href: '/components/input', label: 'Input' },
  { href: '/components/label', label: 'Label' },
  { href: '/components/radio', label: 'Radio' },
  { href: '/components/select', label: 'Select' },
  { href: '/components/table', label: 'Table' },
  { href: '/components/textarea', label: 'Textarea' },
  { href: '/components/dialog', label: 'Dialog' },
  { href: '/components/popover', label: 'Popover' },
  { href: '/components/tooltip', label: 'Tooltip' },
]

const utilities = [
  { href: '/utilities/spacing', label: 'Spacing' },
  { href: '/utilities/flex', label: 'Flex' },
  { href: '/utilities/flow', label: 'Flow' },
  { href: '/utilities/prose', label: 'Prose' },
  { href: '/utilities/ui-typography', label: 'UI Typography' },
  { href: '/utilities/visibility', label: 'Visibility' },
]

const sections = [
  { heading: 'Guide', items: guides },
  { heading: 'Tokens', items: tokens },
  { heading: 'Components', items: components },
  { heading: 'Utilities', items: utilities },
]

function isCurrent(href: string) {
  if (href === '/') return currentPath === '/' || currentPath === ''
  return currentPath.startsWith(href)
}
---

<nav class="sidebar">
  {sections.map(({ heading, items }) => (
    <section>
      <h2 class="section-heading">{heading}</h2>
      <ul>
        {items.map(({ href, label }) => (
          <li>
            <a href={href} class:list={[{ active: isCurrent(href) }]} aria-current={isCurrent(href) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</nav>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
  }

  .section-heading {
    font-size: var(--step--2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    opacity: 0.5;
    margin: 0 0 var(--space-3xs);
    padding: 0 var(--space-xs);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5xs);
  }

  a {
    display: block;
    padding: var(--space-3xs) var(--space-xs);
    font-size: var(--step--1);
    color: var(--color-text);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-radius: 0 0.25rem 0.25rem 0;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  a:hover {
    background-color: color-mix(in oklch, var(--color-text) 8%, transparent);
  }

  a.active {
    border-left-color: var(--color-theme);
    background-color: color-mix(in oklch, var(--color-theme) 10%, transparent);
    font-weight: 600;
  }
</style>

<script>
  let savedScrollTop = 0

  document.addEventListener('astro:before-swap', () => {
    const sidebar = document.querySelector('.site-sidebar')
    if (sidebar) {
      savedScrollTop = sidebar.scrollTop
    }
  })

  document.addEventListener('astro:after-swap', () => {
    const sidebar = document.querySelector('.site-sidebar')
    if (sidebar) {
      sidebar.scrollTop = savedScrollTop
    }
  })
</script>
