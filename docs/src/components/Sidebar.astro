---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props

interface PageFrontmatter {
  title: string
  order?: number
  sectionOrder?: number
}

interface NavItem {
  href: string
  label: string
  exact?: boolean
  order?: number
}

const allPages = import.meta.glob('../pages/**/*.mdx', { eager: true })

function pathToHref(filePath: string): string {
  return filePath
    .replace('../pages', '')
    .replace(/\.mdx$/, '')
    .replace(/\/index$/, '') || '/'
}

function capitalize(str: string): string {
  return str.charAt(0).toUpperCase() + str.slice(1)
}

// Group pages by top-level directory (section)
const sectionMap = new Map<string, { sectionOrder: number; heading: string; items: NavItem[] }>()

for (const [path, mod] of Object.entries(allPages)) {
  const match = path.match(/^\.\.\/pages\/([^/]+)\//)
  if (!match) continue
  const key = match[1]
  const fm = (mod as { frontmatter: PageFrontmatter }).frontmatter
  const isIndex = path.endsWith('/index.mdx')
  const href = pathToHref(path)

  if (!sectionMap.has(key)) {
    sectionMap.set(key, { sectionOrder: Infinity, heading: capitalize(key), items: [] })
  }

  const section = sectionMap.get(key)!

  if (isIndex) {
    section.sectionOrder = fm.sectionOrder ?? Infinity
  }

  section.items.push({
    href,
    label: fm.title,
    exact: isIndex || undefined,
    order: isIndex ? (fm.order ?? 0) : fm.order,
  })
}

const sections = [...sectionMap.values()]
  .sort((a, b) => a.sectionOrder - b.sectionOrder || a.heading.localeCompare(b.heading))
  .map(({ heading, items }) => ({
    heading,
    items: items.sort((a, b) => {
      const aOrdered = a.order !== undefined
      const bOrdered = b.order !== undefined
      if (aOrdered && bOrdered) return a.order! - b.order!
      if (aOrdered) return -1
      if (bOrdered) return 1
      return a.label.localeCompare(b.label)
    }),
  }))

function isCurrent(href: string, exact = false) {
  if (href === '/') return currentPath === '/' || currentPath === ''
  if (exact) return currentPath === href
  return currentPath === href || currentPath.startsWith(href + '/')
}
---

<nav class="sidebar">
  {sections.map(({ heading, items }) => (
    <section>
      <h2 class="section-heading">{heading}</h2>
      <ul>
        {items.map(({ href, label, exact }) => (
          <li>
            <a href={href} class:list={[{ active: isCurrent(href, exact) }]} aria-current={isCurrent(href, exact) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</nav>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
  }

  .section-heading {
    font-size: var(--step--2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    opacity: 0.5;
    margin: 0 0 var(--space-3xs);
    padding: 0 var(--space-xs);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5xs);
  }

  a {
    display: block;
    padding: var(--space-3xs) var(--space-xs);
    font-size: var(--step--1);
    color: var(--color-text);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-radius: 0 0.25rem 0.25rem 0;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  a:hover {
    background-color: color-mix(in oklch, var(--color-text) 8%, transparent);
  }

  a.active {
    border-left-color: var(--color-theme);
    background-color: color-mix(in oklch, var(--color-theme) 10%, transparent);
    font-weight: 600;
  }
</style>

<script>
  let savedScrollTop = 0;

  function scrollActiveIntoView() {
    const sidebar = document.querySelector(".site-sidebar");
    const activeLink = document.querySelector(
      ".site-sidebar .sidebar a.active",
    );
    if (!sidebar || !activeLink) {
      return;
    }
    const sidebarTop = sidebar.scrollTop;
    const sidebarHeight = sidebar.clientHeight;
    const linkTop = activeLink.offsetTop;
    const linkHeight = activeLink.offsetHeight;
    const isVisible =
      linkTop >= sidebarTop &&
      linkTop + linkHeight <= sidebarTop + sidebarHeight;
    if (!isVisible) {
      sidebar.scrollTop = linkTop - sidebarHeight / 2 + linkHeight / 2;
    }
  }

  document.addEventListener("astro:page-load", scrollActiveIntoView);

  document.addEventListener("astro:before-swap", () => {
    const sidebar = document.querySelector(".site-sidebar");
    if (sidebar) {
      savedScrollTop = sidebar.scrollTop;
    }
  });

  document.addEventListener("astro:after-swap", () => {
    const sidebar = document.querySelector(".site-sidebar");
    if (sidebar) {
      sidebar.scrollTop = savedScrollTop;
    }
  });
</script>
