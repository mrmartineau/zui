---
interface Props {
  inline?: boolean
}
const { inline = false } = Astro.props

const themeColorNames = [
  'slate', 'gray', 'zinc', 'neutral', 'stone',
  'mauve', 'olive', 'mist', 'taupe',
]
const accentColorNames = [
  'slate', 'gray', 'zinc', 'neutral', 'stone',
  'mauve', 'olive', 'mist', 'taupe',
  'red', 'orange', 'amber', 'yellow', 'lime', 'green',
  'emerald', 'teal', 'cyan', 'sky', 'blue',
  'indigo', 'violet', 'purple', 'fuchsia', 'pink', 'rose',
]

const fonts = [
  'Geist',
  'Inter',
  'system-ui',
  'Georgia',
  'Charter',
  'Menlo, monospace',
  'Source Code Pro, monospace',
]

const radiusScales = [
  { label: 'None', value: '0' },
  { label: 'Small', value: '0.5' },
  { label: 'Default', value: '1' },
  { label: 'Large', value: '1.5' },
  { label: 'XL', value: '2' },
  { label: 'Full', value: '6' },
]
---

{!inline && (
  <button class="theme-toggle zui-button zui-button-icon zui-button-variant-subtle zui-button-size-xl zui-button-shape-squircle" data-theme-toggle type="button" aria-label="Open theme switcher">
    <i class="ph ph-palette"></i>
  </button>
)}

{inline ? (
  <div class="theme-panel-inline" data-theme-switcher="inline">
    <div class="panel-controls">
      <div class="control-group">
        <label class="control-label" for="ctrl-theme-inline">Theme</label>
        <select class="zui-select" id="ctrl-theme-inline" data-ctrl="theme">
          {themeColorNames.map(name => (
            <option value={name} selected={name === 'mist'}>{name}</option>
          ))}
        </select>
      </div>

      <div class="control-group">
        <label class="control-label" for="ctrl-accent-inline">Accent</label>
        <select class="zui-select" id="ctrl-accent-inline" data-ctrl="accent">
          {accentColorNames.map(name => (
            <option value={name} selected={name === 'sky'}>{name}</option>
          ))}
        </select>
      </div>

      <div class="control-group">
        <label class="control-label" for="ctrl-font-body-inline">Body font</label>
        <select class="zui-select" id="ctrl-font-body-inline" data-ctrl="fontBody">
          {fonts.map(font => (
            <option value={font} selected={font === 'Geist, Inter'}>{font.split(',')[0]}</option>
          ))}
        </select>
      </div>

      <div class="control-group">
        <label class="control-label" for="ctrl-font-display-inline">Display font</label>
        <select class="zui-select" id="ctrl-font-display-inline" data-ctrl="fontDisplay">
          {fonts.map(font => (
            <option value={font} selected={font === 'Geist, Inter'}>{font.split(',')[0]}</option>
          ))}
        </select>
      </div>

      <div class="control-group">
        <label class="control-label" for="ctrl-radius-inline">Corners</label>
        <select class="zui-select" id="ctrl-radius-inline" data-ctrl="radius">
          {radiusScales.map(({ label, value }) => (
            <option value={value} selected={value === '1'}>{label}</option>
          ))}
        </select>
      </div>
    </div>

    <p class="zui-color-muted">Copy this CSS to your project:</p>
    <pre class="zui-pre panel-preview"><code data-theme-code></code></pre>

    <div class="panel-actions-inline">
      <button class="zui-button zui-button-variant-outline zui-button-size-sm" data-theme-copy type="button">Copy CSS</button>
      <button class="zui-button zui-button-variant-outline zui-button-size-sm" data-theme-reset type="button">Reset</button>
    </div>
  </div>
) : (
  <dialog class="theme-dialog" data-theme-switcher="global" data-theme-dialog>
    <div class="panel-header">
      <h3 class="panel-title">Theme</h3>
      <div class="panel-actions">
        <button class="zui-button zui-button-variant-outline zui-button-size-sm" data-theme-copy type="button">Copy CSS</button>
        <button class="zui-button zui-button-variant-outline zui-button-size-sm" data-theme-reset type="button">Reset</button>
        <button class="zui-button zui-button-icon zui-button-variant-ghost zui-button-size-sm" data-theme-close type="button" aria-label="Close"><i class="ph ph-x"></i></button>
      </div>
    </div>

    <div class="panel-body">
      <div class="panel-controls">
        <div class="control-group">
          <label class="control-label" for="ctrl-theme">Theme</label>
          <select class="zui-select" id="ctrl-theme" data-ctrl="theme">
            {themeColorNames.map(name => (
              <option value={name} selected={name === 'mist'}>{name}</option>
            ))}
          </select>
        </div>

        <div class="control-group">
          <label class="control-label" for="ctrl-accent">Accent</label>
          <select class="zui-select" id="ctrl-accent" data-ctrl="accent">
            {accentColorNames.map(name => (
              <option value={name} selected={name === 'sky'}>{name}</option>
            ))}
          </select>
        </div>

        <div class="control-group">
          <label class="control-label" for="ctrl-font-body">Body font</label>
          <select class="zui-select" id="ctrl-font-body" data-ctrl="fontBody">
            {fonts.map(font => (
              <option value={font} selected={font === 'Geist, Inter'}>{font.split(',')[0]}</option>
            ))}
          </select>
        </div>

        <div class="control-group">
          <label class="control-label" for="ctrl-font-display">Display font</label>
          <select class="zui-select" id="ctrl-font-display" data-ctrl="fontDisplay">
            {fonts.map(font => (
              <option value={font} selected={font === 'Geist, Inter'}>{font.split(',')[0]}</option>
            ))}
          </select>
        </div>

        <div class="control-group">
          <label class="control-label" for="ctrl-radius">Corners</label>
          <select class="zui-select" id="ctrl-radius" data-ctrl="radius">
            {radiusScales.map(({ label, value }) => (
              <option value={value} selected={value === '1'}>{label}</option>
            ))}
          </select>
        </div>
      </div>

      <p class="zui-color-muted">Copy this CSS to your project:</p>
      <pre class="zui-pre panel-preview"><code data-theme-code></code></pre>
    </div>
  </dialog>
)}

<script>
  const defaults = {
    theme: 'mist',
    accent: 'sky',
    fontBody: 'Geist, Inter',
    fontDisplay: 'Geist, Inter',
    radius: '1',
  }

  function getValues(container: Element) {
    return {
      theme: (container.querySelector('[data-ctrl="theme"]') as HTMLSelectElement)?.value ?? defaults.theme,
      accent: (container.querySelector('[data-ctrl="accent"]') as HTMLSelectElement)?.value ?? defaults.accent,
      fontBody: (container.querySelector('[data-ctrl="fontBody"]') as HTMLSelectElement)?.value ?? defaults.fontBody,
      fontDisplay: (container.querySelector('[data-ctrl="fontDisplay"]') as HTMLSelectElement)?.value ?? defaults.fontDisplay,
      radius: (container.querySelector('[data-ctrl="radius"]') as HTMLSelectElement)?.value ?? defaults.radius,
    }
  }

  function applyTheme(theme: string, accent: string, fontBody: string, fontDisplay: string, radius: string) {
    const root = document.documentElement
    root.style.setProperty('--color-theme', `light-dark(var(--color-${theme}-600), var(--color-${theme}-400))`)
    root.style.setProperty('--color-accent', `light-dark(var(--color-${accent}-600), var(--color-${accent}-400))`)
    root.style.setProperty('--color-background', `light-dark(var(--color-${theme}-200), var(--color-${theme}-800))`)
    root.style.setProperty('--color-surface', `light-dark(var(--color-${theme}-100), var(--color-${theme}-900))`)
    root.style.setProperty('--color-border', `light-dark(var(--color-${theme}-300), var(--color-${theme}-700))`)
    root.style.setProperty('--color-text', `light-dark(var(--color-${theme}-700), var(--color-${theme}-300))`)
    root.style.setProperty('--font-body', fontBody)
    root.style.setProperty('--font-display', fontDisplay)
    root.style.setProperty('--radius-scale', radius)
  }

  function getFullCSS(theme: string, accent: string, fontBody: string, fontDisplay: string, radius: string) {
    return `:root {
  --color-theme: light-dark(var(--color-${theme}-600), var(--color-${theme}-400));
  --color-accent: light-dark(var(--color-${accent}-600), var(--color-${accent}-400));
  --color-background: light-dark(var(--color-${theme}-200), var(--color-${theme}-800));
  --color-surface: light-dark(var(--color-${theme}-100), var(--color-${theme}-900));
  --color-border: light-dark(var(--color-${theme}-300), var(--color-${theme}-700));
  --color-text: light-dark(var(--color-${theme}-700), var(--color-${theme}-300));
  --font-body: ${fontBody};
  --font-display: ${fontDisplay};
  --radius-scale: ${radius};
}`
  }

  function syncAllPreviews(theme: string, accent: string, fontBody: string, fontDisplay: string, radius: string) {
    const css = getFullCSS(theme, accent, fontBody, fontDisplay, radius)
    document.querySelectorAll('[data-theme-code]').forEach(el => {
      el.textContent = css
    })
  }

  function syncAllControls(container: Element, values: ReturnType<typeof getValues>) {
    // Sync the other switcher instance's controls to match
    document.querySelectorAll('[data-theme-switcher]').forEach(other => {
      if (other === container) return
      const set = (ctrl: string, val: string) => {
        const el = other.querySelector(`[data-ctrl="${ctrl}"]`) as HTMLSelectElement | null
        if (el) el.value = val
      }
      set('theme', values.theme)
      set('accent', values.accent)
      set('fontBody', values.fontBody)
      set('fontDisplay', values.fontDisplay)
      set('radius', values.radius)
    })
  }

  function initSwitcher(container: Element) {
    const isDialog = container.hasAttribute('data-theme-dialog')
    const dialog = isDialog ? container as HTMLDialogElement : null
    const toggleBtn = document.querySelector('[data-theme-toggle]')
    const closeBtn = container.querySelector('[data-theme-close]')
    const copyBtn = container.querySelector('[data-theme-copy]')
    const resetBtn = container.querySelector('[data-theme-reset]')

    if (dialog && toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        dialog.open ? dialog.close() : dialog.show()
      })
    }

    if (closeBtn && dialog) {
      closeBtn.addEventListener('click', () => dialog.close())
    }

    const controls = container.querySelectorAll('[data-ctrl]')
    controls.forEach(ctrl => {
      ctrl.addEventListener('change', () => {
        const values = getValues(container)
        applyTheme(values.theme, values.accent, values.fontBody, values.fontDisplay, values.radius)
        syncAllPreviews(values.theme, values.accent, values.fontBody, values.fontDisplay, values.radius)
        syncAllControls(container, values)
      })
    })

    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const values = getValues(container)
        const css = getFullCSS(values.theme, values.accent, values.fontBody, values.fontDisplay, values.radius)
        navigator.clipboard.writeText(css).then(() => {
          const orig = copyBtn.textContent
          copyBtn.textContent = 'Copied!'
          setTimeout(() => { copyBtn.textContent = orig }, 1500)
        })
      })
    }

    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        controls.forEach(ctrl => {
          const el = ctrl as HTMLSelectElement
          const key = el.dataset.ctrl as keyof typeof defaults
          if (key in defaults) el.value = defaults[key]
        })

        const root = document.documentElement
        root.style.removeProperty('--color-theme')
        root.style.removeProperty('--color-accent')
        root.style.removeProperty('--color-background')
        root.style.removeProperty('--color-surface')
        root.style.removeProperty('--color-border')
        root.style.removeProperty('--color-text')
        root.style.removeProperty('--font-body')
        root.style.removeProperty('--font-display')
        root.style.removeProperty('--radius-scale')

        syncAllPreviews(defaults.theme, defaults.accent, defaults.fontBody, defaults.fontDisplay, defaults.radius)
        syncAllControls(container, defaults)
      })
    }

    // Initial preview render
    const values = getValues(container)
    syncAllPreviews(values.theme, values.accent, values.fontBody, values.fontDisplay, values.radius)
  }

  function init() {
    document.querySelectorAll('[data-theme-switcher]').forEach(initSwitcher)
  }

  document.addEventListener('astro:page-load', init)
</script>

<style>
  .theme-toggle {
    position: fixed;
    bottom: var(--space-md);
    right: var(--space-md);
    z-index: var(--z-4);
    justify-content: center;
    box-shadow: var(--shadow-md);
  }

  .theme-toggle:hover {
    background-color: color-mix(in oklch, var(--color-theme) 15%, var(--color-surface));
    transform: scale(1.05);
  }

  .theme-dialog {
    position: fixed;
    bottom: calc(var(--space-md) + 60px);
    right: var(--space-md);
    left: auto;
    top: auto;
    width: 420px;
    max-height: calc(100dvh - 120px);
    overflow-y: auto;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: 0;
    margin: 0;
    z-index: var(--z-4);
    color: var(--color-text);
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .panel-title {
    margin: 0;
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--color-text);
  }

  .panel-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3xs);
  }

  .panel-body {
    padding: var(--space-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .panel-preview {
    font-size: var(--step--3);
    padding: var(--space-2xs);
    overflow-x: auto;
    max-height: 150px;
  }

  .panel-controls {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xs);
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xs);
  }

  .control-label {
    font-size: var(--step--2);
    font-weight: 500;
    color: var(--color-text);
    opacity: 0.7;
  }

  /* Inline variant */
  .theme-panel-inline {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-sm);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .panel-actions-inline {
    display: flex;
    gap: var(--space-3xs);
  }

  @media (max-width: 480px) {
    .theme-dialog {
      width: calc(100vw - var(--space-md) * 2);
      right: var(--space-md);
    }

    .panel-controls {
      grid-template-columns: 1fr;
    }
  }
</style>
