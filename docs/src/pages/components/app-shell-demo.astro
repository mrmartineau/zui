---
import {
  AppShell,
  AppShellHeader,
  AppShellMain,
  AppShellSidebar,
  AppShellSidebarBody,
  AppShellSidebarFooter,
  AppShellSidebarHeader,
} from '@mrmartineau/zui/astro'
import '@mrmartineau/zui/css'
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AppShell demo</title>
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2/src/regular/style.css"
    />
    <style>
      html, body { margin: 0; padding: 0; height: 100%; }
      a.nav-link {
        display: flex;
        align-items: center;
        gap: var(--space-xs);
        padding: var(--space-2xs) var(--space-xs);
        border-radius: var(--radius-md);
        color: inherit;
        text-decoration: none;
      }
      a.nav-link:hover {
        background-color: oklch(from var(--color-text) l c h / 8%);
      }
      a.nav-link i { font-size: var(--step-1); }
      .brand {
        font-weight: 700;
        font-size: var(--step-1);
      }
    </style>
  </head>
  <body>
    <AppShell shortcut>
      <AppShellSidebar>
        <AppShellSidebarHeader>
          <i class="ph ph-sparkle" aria-hidden="true" style="font-size:var(--step-2)"></i>
          <span class="brand">Acme</span>
        </AppShellSidebarHeader>
        <AppShellSidebarBody>
          <nav>
            <a class="nav-link" href="#">
              <i class="ph ph-house" aria-hidden="true"></i>
              <span>Home</span>
            </a>
            <a class="nav-link" href="#">
              <i class="ph ph-folder" aria-hidden="true"></i>
              <span>Projects</span>
            </a>
            <a class="nav-link" href="#">
              <i class="ph ph-chat-circle" aria-hidden="true"></i>
              <span>Inbox</span>
            </a>
            <a class="nav-link" href="#">
              <i class="ph ph-chart-bar" aria-hidden="true"></i>
              <span>Reports</span>
            </a>
          </nav>
        </AppShellSidebarBody>
        <AppShellSidebarFooter>
          <i class="ph ph-user-circle" aria-hidden="true" style="font-size:var(--step-1)"></i>
          <span>Account</span>
        </AppShellSidebarFooter>
      </AppShellSidebar>

      <AppShellHeader>
        <strong style="margin-inline-start:var(--space-xs)">Dashboard</strong>
        <span style="flex:1"></span>
        <button class="zui-button zui-button-variant-outline" type="button">
          <i class="ph ph-bell" aria-hidden="true"></i>
        </button>
      </AppShellHeader>

      <AppShellMain>
        <h1>Welcome</h1>
        <p>
          This is the main content area. Try the toggle button in the header
          (or press <kbd>Cmd/Ctrl + B</kbd>) to collapse the sidebar into an
          icon rail. Resize the frame to below 768px to see the mobile drawer
          mode.
        </p>
      </AppShellMain>
    </AppShell>
  </body>
</html>
