---
import { Code } from 'astro:components'
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
  Tooltip,
} from '@mrmartineau/zui/astro'
import { version } from '../../../packages/zui/package.json'
import Layout from '../layouts/HomeLayout.astro'

const allMdxPages = import.meta.glob('./**/*.mdx', { eager: true })

const componentCount = Object.keys(allMdxPages).filter(
  (path) => path.startsWith('./components/') && !path.endsWith('/index.mdx'),
).length

const stats = [
  { label: 'Components', value: String(componentCount) },
  { label: 'Framework wrappers', value: '5' },
  { label: 'JS runtime', value: '0kB' },
  { label: 'Theme file', value: '1' },
]

// Mini live previews that mirror the demo themes from /guides/theming-showcase.
// Colours use the same light-dark() pairs as the real themes so the tiles
// follow the docs' colour scheme. Terminal is pinned dark (its pen forces
// zui-dark); Brutalist inverts to black-on-dark.
const themePreviews = [
  {
    accent: 'light-dark(var(--color-rose-600), var(--color-rose-400))',
    bg: 'light-dark(oklch(0.98 0.02 70), var(--color-stone-900))',
    border: 'light-dark(oklch(0.9 0.03 60), var(--color-stone-700))',
    font: 'var(--font-stack-serif)',
    name: 'Golden Hour',
    note: 'Warm serif editorial',
    onAccent: 'light-dark(#ffffff, oklch(0.2 0.05 20))',
    radius: '10px',
    surface: 'light-dark(oklch(1 0.008 80), var(--color-stone-800))',
    text: 'light-dark(var(--color-stone-800), var(--color-stone-100))',
  },
  {
    accent: 'oklch(0.86 0.21 150)',
    bg: 'oklch(0.17 0.02 150)',
    border: 'oklch(0.34 0.04 150)',
    font: 'var(--font-stack-mono)',
    name: 'Terminal',
    note: 'Mono, dark, zero radius',
    onAccent: '#0a0e0a',
    radius: '0',
    surface: 'oklch(0.21 0.02 150)',
    text: 'oklch(0.9 0.07 150)',
  },
  {
    accent: 'light-dark(var(--color-fuchsia-600), var(--color-fuchsia-400))',
    bg: 'light-dark(oklch(0.97 0.03 340), oklch(0.2 0.05 330))',
    border: 'light-dark(oklch(0.9 0.06 335), oklch(0.35 0.06 330))',
    font: 'var(--font-stack-sans)',
    name: 'Bubblegum',
    note: 'Round & playful',
    onAccent: 'light-dark(#ffffff, oklch(0.2 0.08 330))',
    radius: '18px',
    surface: 'light-dark(#ffffff, oklch(0.25 0.05 330))',
    text: 'light-dark(oklch(0.36 0.11 340), oklch(0.94 0.03 340))',
  },
  {
    accent: 'light-dark(var(--color-blue-600), var(--color-blue-400))',
    bg: 'light-dark(var(--color-slate-100), var(--color-slate-900))',
    border: 'light-dark(var(--color-slate-300), var(--color-slate-700))',
    font: 'var(--font-stack-sans)',
    name: 'Nordic',
    note: 'Crisp & corporate',
    onAccent: 'light-dark(#ffffff, oklch(0.2 0.06 250))',
    radius: '3px',
    surface: 'light-dark(#ffffff, var(--color-slate-800))',
    text: 'light-dark(var(--color-slate-800), var(--color-slate-200))',
  },
  {
    accent: 'var(--color-yellow-400)',
    bg: 'light-dark(#faf9f0, #111111)',
    border: 'light-dark(#111111, #fafafa)',
    font: 'var(--font-stack-sans)',
    name: 'Brutalist',
    note: 'High-contrast, square',
    onAccent: '#111111',
    radius: '0',
    surface: 'light-dark(#ffffff, #1a1a1a)',
    text: 'light-dark(#111111, #fafafa)',
  },
]

const tokenColors = [
  'var(--color-rose-500)',
  'var(--color-orange-500)',
  'var(--color-amber-400)',
  'var(--color-emerald-500)',
  'var(--color-sky-500)',
  'var(--color-violet-500)',
]
---

<Layout>
  <section class="hero">
    <div class="hero-name">ZUI</div>
    <!-- <div class="hero-badges">
      <span class="zui-badge zui-badge-variant-outline">v{version}</span>
      <span class="zui-badge">CSS-first &middot; No build step</span>
    </div> -->
    <h1 class="hero-title">A CSS-first UI library that's fully themeable and agent&nbsp;ready</h1>
    <p class="hero-subtitle">Browse {componentCount} accessible components, tune every token to match your brand, and ship with zero JS runtime &mdash; pick a starting point and go. Optional <a href="/guides/react">React</a>, <a href="/guides/astro">Astro</a>, <a href="/guides/solid">Solid</a>, <a href="/guides/svelte">Svelte</a> &amp; <a href="/guides/vue">Vue</a> wrappers included.</p>
    <div class="hero-actions">
      <a href="/guides" class="zui-button zui-button-shape-squircle">Get started</a>
      <a href="/components" class="zui-button zui-button-variant-outline zui-button-shape-squircle">Browse components</a>
      <a href="https://github.com/mrmartineau/zui" class="zui-button zui-button-variant-ghost zui-button-shape-squircle"><i class="ph ph-github-logo"></i> GitHub</a>
    </div>
    <div class="hero-install">
      <Code code="npm install @mrmartineau/zui" lang="bash" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
      <a href="https://codepen.io/mrmartineau/pen/gbwoRZj?editors=1100" class="hero-install-alt"><i class="ph ph-codepen-logo"></i> or try it on CodePen</a>
    </div>
  </section>

  <section class="stats" aria-label="ZUI at a glance">
    <ul class="stats-grid">
      {stats.map(({ label, value }) => (
        <li class="stat">
          <span class="stat-value">{value}</span>
          <span class="stat-label">{label}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="starting-points">
    <header class="section-header">
      <p class="section-eyebrow">Explore</p>
      <h2 class="section-title">Pick a starting point</h2>
      <p class="section-lede">Everything in ZUI is built from the same three ingredients: components, a theme, and the tokens beneath them. Start wherever suits your project.</p>
    </header>
    <div class="start-grid">
      <a href="/components" class="start-card">
        <div class="start-card-preview" aria-hidden="true">
          <span class="zui-button">Button</span>
          <span class="zui-badge zui-badge-color-green">Badge</span>
          <span class="zui-avatar"><span class="zui-avatar-fallback">ZM</span></span>
          <kbd class="zui-kbd-group"><kbd class="zui-kbd">⌘</kbd><kbd class="zui-kbd">K</kbd></kbd>
          <span class="zui-button zui-button-variant-outline">Outline</span>
          <span class="zui-badge zui-badge-variant-fill">Fill</span>
        </div>
        <div class="start-card-body">
          <h3 class="start-card-title">Components <i class="ph ph-arrow-right"></i></h3>
          <p class="start-card-description">{componentCount} accessible, themeable building blocks &mdash; from buttons and forms to dialogs, menus, and a full app shell.</p>
        </div>
      </a>

      <a href="/guides/theming" class="start-card">
        <div class="start-card-preview" aria-hidden="true">
          {themePreviews.map((theme) => (
            <span
              class="start-theme-chip"
              style={`--tc-bg:${theme.surface};--tc-border:${theme.border};--tc-text:${theme.text};--tc-radius:${theme.radius};--tc-font:${theme.font}`}
            >Aa</span>
          ))}
        </div>
        <div class="start-card-body">
          <h3 class="start-card-title">Theming <i class="ph ph-arrow-right"></i></h3>
          <p class="start-card-description">Override one <code>theme.css</code> file and every component follows &mdash; colours, fonts, radii, and light/dark schemes.</p>
        </div>
      </a>

      <a href="/tokens" class="start-card">
        <div class="start-card-preview" aria-hidden="true">
          <span class="start-token-row">
            {tokenColors.map((color) => (
              <span class="start-token-dot" style={`--td-color:${color}`}></span>
            ))}
          </span>
          <span class="start-token-row">
            <span class="start-token-bar" style="width:14%"></span>
            <span class="start-token-bar" style="width:24%"></span>
            <span class="start-token-bar" style="width:38%"></span>
          </span>
        </div>
        <div class="start-card-body">
          <h3 class="start-card-title">Tokens <i class="ph ph-arrow-right"></i></h3>
          <p class="start-card-description">Colours, spacing, type scale, shadows, radii, easing, and z-index &mdash; all exposed as CSS custom properties.</p>
        </div>
      </a>
    </div>
  </section>

  <section class="showcase">
    <header class="section-header">
      <p class="section-eyebrow">Component library</p>
      <h2 class="section-title">Real components, rendered live</h2>
      <p class="section-lede">Nothing on this page is a screenshot. Every control below is the shipped CSS, running in your colour scheme &mdash; try the tabs.</p>
    </header>
    <div class="showcase-grid">
      <div class="showcase-panel">
        <span class="showcase-label">Buttons</span>
        <div class="showcase-row">
          <button class="zui-button">Primary</button>
          <button class="zui-button zui-button-variant-outline">Outline</button>
          <button class="zui-button zui-button-variant-ghost">Ghost</button>
          <button class="zui-button zui-button-variant-subtle">Subtle</button>
          <button class="zui-button zui-button-variant-link">Link</button>
        </div>
      </div>

      <div class="showcase-panel">
        <span class="showcase-label">Badges</span>
        <div class="showcase-row">
          <span class="zui-badge">Default</span>
          <span class="zui-badge zui-badge-variant-fill">Fill</span>
          <span class="zui-badge zui-badge-variant-outline">Outline</span>
          <span class="zui-badge zui-badge-color-green">Green</span>
          <span class="zui-badge zui-badge-color-red">Red</span>
          <span class="zui-badge zui-badge-color-amber">Amber</span>
        </div>
      </div>

      <div class="showcase-panel showcase-panel-wide">
        <span class="showcase-label">Tabs</span>
        <Tabs defaultValue="preview">
          <TabsList aria-label="Tabs demo">
            <TabsTrigger value="preview">Preview</TabsTrigger>
            <TabsTrigger value="code">Code</TabsTrigger>
            <TabsTrigger value="tokens">Tokens</TabsTrigger>
          </TabsList>
          <TabsContent value="preview">Fully keyboard-accessible tabs, styled with plain CSS.</TabsContent>
          <TabsContent value="code">Use plain classes, or the React, Astro, Solid, Svelte &amp; Vue wrappers.</TabsContent>
          <TabsContent value="tokens">Every colour and radius here comes from a design token.</TabsContent>
        </Tabs>
      </div>

      <div class="showcase-panel">
        <span class="showcase-label">Form controls</span>
        <div class="showcase-stack">
          <div class="zui-field">
            <label class="zui-label" for="demo-input">Email address</label>
            <input class="zui-input" id="demo-input" type="email" placeholder="you@example.com" />
          </div>
          <div class="showcase-row">
            <label class="zui-checkbox" style="display:flex;align-items:center;gap:var(--space-3xs)">
              <input type="checkbox" checked />
              Remember me
            </label>
            <select class="zui-select" style="width:auto;">
              <option>Option A</option>
              <option>Option B</option>
            </select>
          </div>
        </div>
      </div>

      <div class="showcase-panel">
        <span class="showcase-label">Card</span>
        <div class="zui-card">
          <div class="zui-card-header">
            <div class="zui-card-title">Notification settings</div>
            <div class="zui-card-description">Choose what you want to be notified about.</div>
          </div>
          <div class="zui-card-body">
            <label class="zui-checkbox" style="display:flex;align-items:center;gap:var(--space-3xs)">
              <input type="checkbox" checked />
              Email notifications
            </label>
          </div>
        </div>
      </div>

      <div class="showcase-panel showcase-panel-wide">
        <span class="showcase-label">Inline pieces</span>
        <div class="showcase-row">
          <span class="zui-avatar"><span class="zui-avatar-fallback">ZM</span></span>
          <kbd class="zui-kbd-group"><kbd class="zui-kbd">⌘</kbd><kbd class="zui-kbd">K</kbd></kbd>
          <kbd class="zui-kbd">Esc</kbd>
          <span class="zui-badge zui-badge-color-blue">v{version}</span>
          <Tooltip text="Popover API + CSS anchor positioning">
            <button class="zui-button zui-button-variant-outline">Hover me</button>
          </Tooltip>
        </div>
      </div>
    </div>
    <a href="/components" class="section-more">Browse all {componentCount} components <i class="ph ph-arrow-right"></i></a>
  </section>

  <section class="theming">
    <header class="section-header">
      <p class="section-eyebrow">Theming</p>
      <h2 class="section-title">One theme file, infinite looks</h2>
      <p class="section-lede">Every ZUI component reads from a small set of semantic custom properties. Override that <code>:root</code> block and the whole UI transforms&mdash;colours, typography, radius, and borders all follow. Same markup, five very different personalities:</p>
    </header>
    <ul class="theming-swatches">
      {themePreviews.map((theme) => (
        <li
          class="theming-swatch"
          style={`--sw-bg:${theme.bg};--sw-surface:${theme.surface};--sw-border:${theme.border};--sw-text:${theme.text};--sw-accent:${theme.accent};--sw-on-accent:${theme.onAccent};--sw-radius:${theme.radius};--sw-font:${theme.font}`}
        >
          <div class="theming-swatch-preview">
            <span class="theming-swatch-tag">Aa</span>
            <span class="theming-swatch-btn">Button</span>
          </div>
          <span class="theming-swatch-name">{theme.name}</span>
          <span class="theming-swatch-note">{theme.note}</span>
        </li>
      ))}
    </ul>
    <a href="/guides/theming-showcase" class="section-more">Explore the theming showcase <i class="ph ph-arrow-right"></i></a>
  </section>

  <section class="agents">
    <header class="section-header">
      <p class="section-eyebrow">AI tooling</p>
      <h2 class="section-title">Built for people &mdash; and their agents</h2>
      <p class="section-lede">Design systems are increasingly consumed by coding agents, not just humans. ZUI ships the tooling both need: a skill that teaches assistants the real class names and tokens, and a CLI that copies the source straight into your project.</p>
    </header>
    <div class="agents-grid">
      <a href="/guides/skills" class="agent-card">
        <i class="ph-duotone ph-robot agent-card-icon"></i>
        <h3 class="agent-card-title">Agent skill</h3>
        <p class="agent-card-description">Install the ZUI skill for Claude Code, Cursor, and other assistants. The model learns ZUI's classes, tokens, and conventions &mdash; no hallucinated class names.</p>
        <Code code="npx skills add mrmartineau/zui" lang="bash" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
      </a>
      <a href="/guides/copy-source" class="agent-card">
        <i class="ph-duotone ph-copy agent-card-icon"></i>
        <h3 class="agent-card-title">Copy the source</h3>
        <p class="agent-card-description">Want full control? Copy every component, token, and stylesheet directly into your project &mdash; no package dependency required.</p>
        <Code code="npx @mrmartineau/zui init" lang="bash" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
      </a>
      <a href="/guides/vscode-extension" class="agent-card">
        <i class="ph-duotone ph-code agent-card-icon"></i>
        <h3 class="agent-card-title">Editor tooling</h3>
        <p class="agent-card-description">The VS Code extension autocompletes ZUI class names and design tokens as you type, with hover docs for every custom property.</p>
      </a>
    </div>
  </section>

  <section class="features">
    <header class="section-header">
      <p class="section-eyebrow">Principles</p>
      <h2 class="section-title">Why ZUI</h2>
    </header>
    <div class="features-grid">
      <div class="feature">
        <h3>CSS-first</h3>
        <p>Standard CSS with <code>@layer</code> for clean cascade control. Custom properties for full configurability. Import and go&mdash;no build step, no&nbsp;JS&nbsp;runtime.</p>
      </div>

      <div class="feature">
        <h3>Framework wrappers</h3>
        <p>Use plain CSS classes anywhere, or reach for typed React, Astro, Solid, Svelte, and Vue component wrappers that map props to the underlying class API.</p>
        <div class="feature-links">
          <a href="/guides/react" class="feature-link">React</a>
          <a href="/guides/astro" class="feature-link">Astro</a>
          <a href="/guides/solid" class="feature-link">Solid</a>
          <a href="/guides/svelte" class="feature-link">Svelte</a>
          <a href="/guides/vue" class="feature-link">Vue</a>
        </div>
      </div>

      <div class="feature">
        <h3>Themeable in seconds</h3>
        <p>Override semantic colours, fonts, and border radii through one <code>theme.css</code> file. Supports <code>light-dark()</code> colour schemes natively.</p>
        <a href="/guides/theming-showcase" class="feature-link">See it in action</a>
      </div>

      <div class="feature">
        <h3>Design tokens</h3>
        <p>A comprehensive token system&mdash;colours, spacing, type scale, shadows, radii, easing, z-index&mdash;all exposed as CSS custom properties.</p>
      </div>

      <div class="feature">
        <h3>Layered architecture</h3>
        <p>Base, component, and utility layers keep specificity predictable. Override anything without <code>!important</code> hacks.</p>
      </div>

      <div class="feature">
        <h3>Modern CSS</h3>
        <p>Built on <code>oklch()</code>, relative colour syntax, <code>light-dark()</code>, and container queries. Designed for how CSS works today.</p>
      </div>
    </div>
  </section>

  <section class="quickstart">
    <header class="section-header">
      <p class="section-eyebrow">Quick start</p>
      <h2 class="section-title">Up and running in three steps</h2>
    </header>
    <div class="quickstart-steps">
      <div class="step">
        <span class="step-number">1</span>
        <div class="step-content">
          <h3>Install</h3>
          <Code code="npm install @mrmartineau/zui" lang="bash" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
        </div>
      </div>
      <div class="step">
        <span class="step-number">2</span>
        <div class="step-content">
          <h3>Import</h3>
          <Code code={`@import '@mrmartineau/zui/css';`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
        </div>
      </div>
      <div class="step">
        <span class="step-number">3</span>
        <div class="step-content">
          <h3>Use</h3>
          <Code code={`<button class="zui-button">Click me</button>`} lang="html" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero ------------------------------------------------------------------ */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: var(--space-xl) var(--space-2xl);

    &::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #A0286C;
      background: linear-gradient(180deg, var(--color-theme), var(--color-background));
      background-size: cover;
      background-position: center;
      opacity: 0.3;
      z-index: -1;
    }
  }

  .hero-badges {
    display: flex;
    gap: var(--space-2xs);
    margin-block: var(--space-md);
  }

  .hero-badges abbr {
    font-family: var(--font-code);
    text-decoration-style: wavy;
    text-decoration-color: oklch(from currentColor l c h / 30%);
  }

  .hero-name {
    font-size: clamp(4rem, 13vw, 13rem);
    font-family: "Bagel Fat One", var(--font-display);
    line-height: 1;
    margin-block-end: var(--space-sm);
  }

  .hero-title {
    font-size: var(--step-5);
    font-family: var(--font-display);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-xs);
    letter-spacing: -0.025em;
    text-wrap: balance;
    max-width: 22ch;
    margin: 0;
    color: var(--color-text);
  }

  .hero-subtitle {
    font-size: var(--step-1);
    line-height: var(--line-height-md);
    color: color-mix(in oklch, var(--color-text) 70%, transparent);
    text-wrap: balance;
    max-width: 55ch;
    margin-block-start: var(--space-md);
  }

  .hero-subtitle a {
    color: var(--color-text);
    text-decoration-line: underline;
    text-decoration-color: oklch(from var(--color-text) l c h / 50%);
    text-decoration-thickness: 0.2ex;
    text-underline-offset: 0.3ex;
    transition: text-decoration-color 0.2s var(--ease-in-out);
  }

  .hero-subtitle a:hover {
    text-decoration-color: oklch(from var(--color-text) l c h / 90%);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-xs);
    margin-block-start: var(--space-lg);
  }

  .hero-install {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
    margin-block-start: var(--space-lg);
  }

  .hero-install :global(pre) {
    margin: 0;
    min-width: 32ch;
    text-align: left;
  }

  .hero-install-alt {
    font-size: var(--step--1);
    color: color-mix(in oklch, var(--color-text) 60%, transparent);
    text-decoration: none;
  }

  .hero-install-alt:hover {
    color: var(--color-theme);
  }

  /* Stats ------------------------------------------------------------------ */
  .stats {
    border-block: 1px solid var(--color-border);
    padding-block: var(--space-md);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4xs);
    text-align: center;
  }

  .stat-value {
    font-size: var(--step-3);
    font-family: var(--font-display);
    font-weight: 800;
    line-height: 1;
    color: var(--color-theme);
    margin: 0;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: var(--step--2);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: color-mix(in oklch, var(--color-text) 55%, transparent);
  }

  /* Section headers --------------------------------------------------------- */
  section {
    padding-block: var(--space-xl);
  }

  section + section {
    border-top: 1px solid var(--color-border);
  }

  .stats + .starting-points {
    border-top: 0;
  }

  .section-header {
