---
---

<button
  id="dark-mode-toggle"
  class="zui-button zui-button-variant-ghost"
  type="button"
  aria-label="Toggle color scheme"
  title="Toggle color scheme"
>
  <i class="ph ph-sun" id="dms-icon-sun" hidden></i>
  <i class="ph ph-moon" id="dms-icon-moon" hidden></i>
  <i class="ph ph-monitor" id="dms-icon-system" hidden></i>
</button>

<script>
  import {
    getColorScheme,
    setColorScheme,
    nextColorScheme,
    type ColorScheme,
  } from '@mrmartineau/zui/utils'

  function updateIcon(scheme: ColorScheme) {
    const sun = document.getElementById('dms-icon-sun')
    const moon = document.getElementById('dms-icon-moon')
    const system = document.getElementById('dms-icon-system')
    if (sun) sun.hidden = scheme !== 'light'
    if (moon) moon.hidden = scheme !== 'dark'
    if (system) system.hidden = scheme !== 'system'
  }

  function init() {
    const btn = document.getElementById('dark-mode-toggle')
    if (!btn) return

    updateIcon(getColorScheme())

    btn.addEventListener('click', () => {
      const next = nextColorScheme()
      setColorScheme(next)
      updateIcon(next)
    })

    window
      .matchMedia('(prefers-color-scheme: dark)')
      .addEventListener('change', () => {
        if (getColorScheme() === 'system') updateIcon('system')
      })
  }

  document.addEventListener('astro:page-load', init)
</script>
