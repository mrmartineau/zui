---
/**
 * MiniThemeSwitcher.astro
 *
 * Header control for quick site theming. Renders a swatches button that opens
 * a ZUI popover containing:
 *
 * - a radio grid of the configured mini colour themes (persisted in
 *   localStorage as `mini-theme`, applied as inline token overrides on :root)
 * - a default slot, so a consuming site can inject its own extra theme
 *   controls (e.g. the ZUI docs' showcase themes) into the same popover
 */
import type { MiniTheme } from '../nav'

interface Props {
  themes?: MiniTheme[]
}

const defaultThemes: MiniTheme[] = [
  { color: 'var(--color-slate-500)', id: 'slate' },
  { color: 'var(--color-taupe-500)', id: 'taupe' },
  { color: 'var(--color-mist-500)', id: 'mist' },
  { color: 'var(--color-neutral-500)', id: 'neutral' },
  { color: 'var(--color-mauve-500)', id: 'mauve' },
]

const { themes = defaultThemes } = Astro.props
const popoverId = 'mini-theme-popover'
---

<div class="mini-theme-switcher">
  <button
    type="button"
    class="zui-button zui-button-icon zui-button-variant-ghost zui-button-shape-squircle"
    popovertarget={popoverId}
    style={`anchor-name: --${popoverId}`}
    aria-label="Site theme"
    title="Site theme"
  >
    <i class="ph ph-swatches" aria-hidden="true"></i>
  </button>

  <div
    id={popoverId}
    popover="auto"
    class="zui-popover mini-theme-popover"
    style={`position-anchor: --${popoverId}`}
  >
    <form action="">
      <fieldset>
        <legend class="mini-theme-popover-label">Colour theme</legend>
        <div class="mini-theme-options">
          {themes.map(({ id, color }) => (
            <label class="mini-theme-option" style={`--swatch-color: ${color}`}>
              <input
                type="radio"
                name="mini-theme"
                value={id}
                title={id}
              />
              <span class="mini-theme-option-name">{id}</span>
            </label>
          ))}
        </div>
      </fieldset>
    </form>

    <slot />

    <button
      type="button"
      class="zui-button zui-button-size-xs zui-button-variant-ghost mini-theme-reset"
      data-mini-theme-reset
    >
      <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
      Reset theme
    </button>
  </div>
</div>

<script>
  function initMiniThemeSwitcher() {
    const inputs = document.querySelectorAll<HTMLInputElement>('[name="mini-theme"]')

    function applyTheme(themeName: string) {
      const root = document.documentElement
      root.style.setProperty('--color-theme',      `light-dark(var(--color-${themeName}-600), var(--color-${themeName}-400))`)
      root.style.setProperty('--color-background',  `light-dark(var(--color-${themeName}-200), var(--color-${themeName}-800))`)
      root.style.setProperty('--color-surface',     `light-dark(var(--color-${themeName}-100), var(--color-${themeName}-900))`)
      root.style.setProperty('--color-border',      `light-dark(var(--color-${themeName}-300), var(--color-${themeName}-700))`)
      root.style.setProperty('--color-text',        `light-dark(var(--color-${themeName}-700), var(--color-${themeName}-300))`)
    }

    function restoreTheme() {
      const saved = localStorage.getItem('mini-theme')
      if (!saved) return
      inputs.forEach(input => {
        if (input.value === saved) input.checked = true
      })
      applyTheme(saved)
    }

    inputs.forEach(input => {
      input.addEventListener('change', () => {
        localStorage.setItem('mini-theme', input.value)
        applyTheme(input.value)
      })
    })

    // Clears the mini theme; sites listening on [data-mini-theme-reset] can
    // clear their own slotted theme controls off the same click.
    document.querySelectorAll('[data-mini-theme-reset]').forEach(btn => {
      btn.addEventListener('click', () => {
        localStorage.removeItem('mini-theme')
        inputs.forEach(input => (input.checked = false))
        const root = document.documentElement
        for (const prop of [
          '--color-theme', '--color-background', '--color-surface',
          '--color-border', '--color-text',
        ])
          root.style.removeProperty(prop)
      })
    })

    restoreTheme()
  }

  document.addEventListener('astro:page-load', initMiniThemeSwitcher)
</script>

<style>
  .mini-theme-popover {
    min-width: 14rem;
  }

  .mini-theme-popover form {
    margin: 0;
  }

  .mini-theme-popover fieldset {
    border: 0;
    padding: 0;
    margin: 0;
  }

  .mini-theme-popover-label {
    padding: 0;
    margin-block-end: var(--space-2xs);
    font-size: var(--step--3);
    font-weight: var(--font-weight-6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .mini-theme-options {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(3.6rem, 1fr));
    gap: var(--space-3xs);
  }

  .mini-theme-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4xs);
    padding: var(--space-3xs);
    border-radius: var(--radius-md);
    cursor: pointer;
  }

  .mini-theme-option:hover {
    background: oklch(from var(--color-text) l c h / 0.06);
  }

  .mini-theme-option input[type='radio'] {
    appearance: none;
    width: 1.1rem;
    height: 1.1rem;
    margin: 0;
    border-radius: 50%;
    background-color: var(--swatch-color);
    outline: 2px solid transparent;
    outline-offset: 2px;
    cursor: pointer;
    transition: outline-color 0.15s ease, transform 0.15s ease;
  }

  .mini-theme-option:hover input[type='radio'] {
    transform: scale(1.1);
  }

  .mini-theme-option input[type='radio']:checked {
    outline-color: var(--swatch-color);
  }

  .mini-theme-option-name {
    font-size: var(--step--2);
    color: var(--color-muted);
  }

  .mini-theme-reset {
    width: 100%;
    margin-block-start: var(--space-xs);
  }
</style>
