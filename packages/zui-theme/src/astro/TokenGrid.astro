---
interface Props {
  columns?: number
  class?: string
}

const { columns = 2, class: className } = Astro.props
---

<div class:list={['token-grid', className]} style={`--token-grid-cols: ${columns};`}>
  <slot />
</div>

<style>
  .token-grid {
    display: grid;
    grid-template-columns: max-content repeat(calc(var(--token-grid-cols) - 1), 1fr);
    margin-block: var(--space-sm);
  }
</style>
