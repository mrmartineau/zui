---
import type { NavSection } from '../nav'

interface Props {
  currentPath: string
  sections: NavSection[]
}

const { currentPath, sections } = Astro.props

function isCurrent(href: string, exact = false) {
  if (href === '/') return currentPath === '/' || currentPath === ''
  if (exact) return currentPath === href
  return currentPath === href || currentPath.startsWith(`${href}/`)
}
---

<nav class="sidebar">
  {sections.map(({ heading, items }) => (
    <section>
      <h2 class="section-heading">{heading}</h2>
      <ul>
        {items.map(({ href, label, exact }) => (
          <li>
            <a href={href} class:list={[{ active: isCurrent(href, exact) }]} aria-current={isCurrent(href, exact) ? 'page' : undefined}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</nav>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .section-heading {
    font-size: var(--step--2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin: 0;
    padding: var(--space-xs);
    position: sticky;
    top: 0;
    background-color: var(--color-surface);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5xs);
  }

  a {
    display: block;
    padding: var(--space-4xs) var(--space-xs);
    font-size: var(--step--2);
    color: var(--color-text);
    text-decoration: none;
    border-left: 2px solid transparent;
    border-radius: 0 0.25rem 0.25rem 0;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  a:hover {
    background-color: color-mix(in oklch, var(--color-text) 8%, transparent);
  }

  a.active {
    border-left-color: var(--color-theme);
    background-color: color-mix(in oklch, var(--color-theme) 10%, transparent);
    font-weight: 600;
  }
</style>

<script>
  let savedScrollTop = 0;

  function scrollActiveIntoView() {
    const sidebar = document.querySelector(".site-sidebar");
    const activeLink = document.querySelector(
      ".site-sidebar .sidebar a.active",
    ) as HTMLElement | null;
    if (!sidebar || !activeLink) {
      return;
    }
    const sidebarTop = sidebar.scrollTop;
    const sidebarHeight = sidebar.clientHeight;
    const linkTop = activeLink.offsetTop;
    const linkHeight = activeLink.offsetHeight;
    const isVisible =
      linkTop >= sidebarTop &&
      linkTop + linkHeight <= sidebarTop + sidebarHeight;
    if (!isVisible) {
      sidebar.scrollTop = linkTop - sidebarHeight / 2 + linkHeight / 2;
    }
  }

  document.addEventListener("astro:page-load", scrollActiveIntoView);

  document.addEventListener("astro:before-swap", () => {
    const sidebar = document.querySelector(".site-sidebar");
    if (sidebar) {
      savedScrollTop = sidebar.scrollTop;
    }
  });

  document.addEventListener("astro:after-swap", () => {
    const sidebar = document.querySelector(".site-sidebar");
    if (sidebar) {
      sidebar.scrollTop = savedScrollTop;
    }
  });
</script>
