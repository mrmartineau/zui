---
import type { FooterSection, NavSection, SiteConfig } from '../nav'
import BaseLayout from './BaseLayout.astro'
import Sidebar from './Sidebar.astro'
import TableOfContents from './TableOfContents.astro'

interface Props {
  title?: string
  description?: string
  currentPath: string
  site: SiteConfig
  sections: NavSection[]
  footerSections?: FooterSection[]
}

const {
  title,
  description,
  currentPath,
  site,
  sections,
  footerSections = [],
} = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  currentPath={currentPath}
  site={site}
  sections={sections}
  footerSections={footerSections}
>
  <slot name="head" slot="head" />
  <div class="site-layout">
    <aside class="site-sidebar" transition:animate="none">
      <Sidebar currentPath={currentPath} sections={sections} />
    </aside>
    <main class="site-main docs-prose" transition:animate="fade" data-pagefind-body>
      {title || description ? (
        <div class="page-header">
          {title ? (<h1>{title}</h1>) : null}
          {description ? <p class="page-description">{description}</p> : null}
        </div>
      ) : null}
      <slot />
    </main>
    <TableOfContents />
  </div>
  {Astro.slots.has('theme-menu') && <slot name="theme-menu" slot="theme-menu" />}
  {Astro.slots.has('footer') && <slot name="footer" slot="footer" />}
  <slot name="body-end" slot="body-end" />
</BaseLayout>

<style>
  .site-layout {
    display: grid;
    grid-template-columns: 240px 1fr 200px;
    flex: 1;
  }

  .site-sidebar {
    position: sticky;
    top: var(--site-header-height);
    height: 100dvh;
    overflow-y: auto;
    border-right: 1px solid var(--color-border);
    padding: 0 var(--space-xs) var(--space-sm);
    background-color: var(--color-surface);
  }

  .site-main {
    padding: var(--space-lg) var(--space-xl);
    max-width: 1200px;
    margin: auto;
    width: 100%;
    height: stretch;
  }

  @media (max-width: 1024px) {
    .site-layout {
      grid-template-columns: 240px 1fr;
    }

    .site-layout > :global(.toc) {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .site-layout {
      grid-template-columns: 1fr;
    }

    .site-sidebar {
      display: none;
    }

    .site-main {
      padding: var(--space-md);
    }
  }
</style>
