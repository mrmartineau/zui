---
import { ClientRouter } from 'astro:transitions'
import '@mrmartineau/zui/css'
import '../css/theme.css'
import type { FooterSection, NavSection, SiteConfig } from '../nav'
import DarkModeSwitcher from './DarkModeSwitcher.astro'
import MiniThemeSwitcher from './MiniThemeSwitcher.astro'
import Sidebar from './Sidebar.astro'
import TableOfContents from './TableOfContents.astro'
import ThemeSwitcher from './ThemeSwitcher.astro'

interface Props {
  title?: string
  description?: string
  currentPath: string
  site: SiteConfig
  sections: NavSection[]
  footerSections?: FooterSection[]
}

const {
  title,
  description,
  currentPath,
  site,
  sections,
  footerSections = [],
} = Astro.props

const logo = site.logo ?? site.title
const versionHref = site.versionHref ?? '/changelog'
const phosphor = site.phosphor ?? true
const phosphorVersion = site.phosphorVersion ?? '2.1.2'
const showThemeSwitcher = site.themeSwitcher ?? true
const showMiniThemeSwitcher = site.miniThemeSwitcher ?? true
const showColorSchemeToggle = site.colorSchemeToggle ?? true
const social = site.social ?? []
const pageTitle = title ? `${site.title} — ${title}` : site.title
const metaDescription = description ?? site.description ?? ''
---

<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {metaDescription ? <meta name="description" content={metaDescription} /> : null}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {site.author ? <meta name="author" content={site.author} /> : null}
    <meta name="og:type" content="website" />
    <meta name="og:url" content={Astro.url} />
    <meta name="generator" content={Astro.generator} />
    {phosphor && (
      <>
        <link
          rel="stylesheet"
          type="text/css"
          href={`https://cdn.jsdelivr.net/npm/@phosphor-icons/web@${phosphorVersion}/src/regular/style.css`}
        />
        <link
          rel="stylesheet"
          type="text/css"
          href={`https://cdn.jsdelivr.net/npm/@phosphor-icons/web@${phosphorVersion}/src/duotone/style.css`}
        />
      </>
    )}
    <script is:inline>(function(){var s=localStorage.getItem('zui-color-scheme');if(s==='dark')document.documentElement.classList.add('zui-dark');else if(s==='light')document.documentElement.classList.add('zui-light');})()</script>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-start">
        <a href="/" class="site-logo">{logo}</a>
        {site.version ? (
          <a href={versionHref} class="zui-badge zui-badge-variant-outline site-version">v{site.version}</a>
        ) : null}
      </div>
      <div class="site-header-end">
        {social.map((link) => (
          <a
            href={link.href}
            class="zui-button zui-button-variant-ghost zui-button-shape-squircle"
            aria-label={link.ariaLabel ?? link.label}
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.icon ? <i class={`ph ph-${link.icon}`}></i> : null}
            {link.label ? <span>{link.label}</span> : null}
          </a>
        ))}
        {showMiniThemeSwitcher && <MiniThemeSwitcher themes={site.miniThemes} />}
        {showColorSchemeToggle && <DarkModeSwitcher />}
        <button
          class="mobile-menu-btn zui-button zui-button-variant-ghost zui-button-shape-squircle"
          type="button"
          aria-label="Open navigation"
          onclick="document.getElementById('mobile-nav').showModal()"
        >
          <i class="ph ph-list"></i>
        </button>
      </div>
    </header>

    <dialog id="mobile-nav" class="mobile-nav-dialog">
      <div class="mobile-nav-header">
        <a href="/" class="site-logo">{logo}</a>
        <button
          class="zui-button zui-button-variant-ghost"
          type="button"
          aria-label="Close navigation"
          onclick="document.getElementById('mobile-nav').close()"
        >
          <i class="ph ph-x"></i>
        </button>
      </div>
      <div class="mobile-nav-body">
        <Sidebar currentPath={currentPath} sections={sections} />
      </div>
    </dialog>

    <div class="site-layout">
      <aside class="site-sidebar" transition:animate="none">
        <Sidebar currentPath={currentPath} sections={sections} />
      </aside>
      <main class="site-main docs-prose" transition:animate="fade" data-pagefind-body>
        {title || description ? (
          <div class="page-header">
            {title ? (<h1>{title}</h1>) : null}
            {description ? <p class="page-description">{description}</p> : null}
          </div>
        ) : null}
        <slot />
      </main>
      <TableOfContents />
    </div>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <slot name="footer">
          <p class="site-footer-credit">
            <b>{site.title}</b>
            {site.author ? (
              <>
                {' '}is made by{' '}
                {site.authorHref ? (
                  <a href={site.authorHref}>{site.author}</a>
                ) : (
                  <span>{site.author}</span>
                )}
              </>
            ) : null}
            {site.version ? <> &middot; <a href={versionHref}>v{site.version}</a></> : null}
          </p>
        </slot>
        <nav class="site-footer-nav" aria-label="Footer">
          {footerSections.map(({ label, href }) => (
            <a href={href}>{label}</a>
          ))}
          {social.map((link) => (
            <a
              href={link.href}
              aria-label={link.ariaLabel ?? link.label}
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.icon ? <i class={`ph ph-${link.icon}`}></i> : link.label}
            </a>
          ))}
        </nav>
      </div>
    </footer>

    {showThemeSwitcher && <ThemeSwitcher />}
    <slot name="body-end" />
  </body>
</html>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-md);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface);
    position: sticky;
    top: 0;
    z-index: var(--z-1);
    height:  var(--site-header-height);
  }

  .site-header-start {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .site-version {
    text-decoration: none;
    font-size: var(--step--2);
  }

  .site-header-end {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .mobile-menu-btn {
    display: none;
  }

  .site-logo {
    font-size: var(--step-1);
    font-weight: 700;
    font-family: var(--font-code);
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .site-layout {
    display: grid;
    grid-template-columns: 240px 1fr 200px;
    height: stretch;
  }

  .site-sidebar {
    position: sticky;
    top:  var(--site-header-height);
    height: 100dvh;
    overflow-y: auto;
    border-right: 1px solid var(--color-border);
    padding: 0 var(--space-xs) var(--space-sm);
    background-color: var(--color-surface);
  }

  .site-main {
    padding: var(--space-lg) var(--space-xl);
    max-width: 960px;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-lg) var(--space-md);
    background-color: var(--color-surface);
  }

  .site-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 960px;
    margin-inline: auto;
    gap: var(--space-md);
  }

  .site-footer-credit {
    font-size: var(--step--1);
    color: var(--color-text);
    opacity: 0.6;
    margin: 0;
  }

  .site-footer-credit a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: oklch(from currentColor l c h / 40%);
    text-underline-offset: 0.3ex;
    transition: text-decoration-color 0.2s var(--ease-in-out);
  }

  .site-footer-credit a:hover {
    text-decoration-color: oklch(from currentColor l c h / 80%);
  }

  .site-footer-nav {
    display: flex;
    gap: var(--space-sm);
  }

  .site-footer-nav a {
    font-size: var(--step--1);
    color: var(--color-text);
    opacity: 0.6;
    text-decoration: none;
    transition: opacity 0.2s var(--ease-in-out);
  }

  .site-footer-nav a:hover {
    opacity: 1;
  }

  /* Mobile nav dialog */
  .mobile-nav-dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background-color: var(--color-surface);
    color: var(--color-text);
    z-index: var(--z-4);
    overflow-y: auto;
  }

  .mobile-nav-dialog::backdrop {
    background-color: oklch(0 0 0 / 50%);
  }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav-body {
    padding: var(--space-sm) var(--space-md);
  }

  @media (max-width: 1024px) {
    .site-layout {
      grid-template-columns: 240px 1fr;
    }

    .site-layout > :global(.toc) {
      display: none;
    }
  }

  @media (max-width: 767px) {
    .site-layout {
      grid-template-columns: 1fr;
    }

    .site-sidebar {
      display: none;
    }

    .site-main {
      padding: var(--space-md);
    }

    .mobile-menu-btn {
      display: inline-flex;
    }

    .site-footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
