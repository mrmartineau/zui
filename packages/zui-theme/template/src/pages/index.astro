---
import SectionCards from '../components/SectionCards.astro'
import Layout from '../layouts/Layout.astro'
import { site } from '../site.config'
---

<Layout>
  <section class="hero">
    <h1 class="hero-title">{site.title}</h1>
    <p class="hero-subtitle">{site.description}</p>
    <div class="hero-actions">
      <a href="/guides" class="zui-button">Get started</a>
      <a href="/components" class="zui-button zui-button-variant-outline">Browse components</a>
    </div>
  </section>

  <section class="landing-section">
    <h2>Guides</h2>
    <SectionCards section="guides" />
  </section>

  <section class="landing-section">
    <h2>Components</h2>
    <SectionCards section="components" />
  </section>
</Layout>

<style>
  .hero {
    padding-block: 2vw;
    max-width: 640px;
  }

  .hero-title {
    font-size: var(--step-5);
    font-weight: 800;
    line-height: var(--line-height-xs);
    letter-spacing: -0.025em;
    margin-block: var(--space-sm) var(--space-md);
    color: var(--color-text);
  }

  .hero-subtitle {
    font-size: var(--step-1);
    line-height: var(--line-height-md);
    color: color-mix(in oklch, var(--color-text) 70%, transparent);
    max-width: 50ch;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-xs);
    margin-block-start: var(--space-lg);
  }

  .landing-section {
    padding-block: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }
</style>
