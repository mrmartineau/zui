---
import {
  buildFooterSections,
  buildSidebarSections,
  DocsLayout,
} from '@mrmartineau/zui-theme/astro'
import { site } from '../site.config'

interface Props {
  title?: string
  description?: string
}

// Frontmatter is passed when this layout is used from an `.mdx` page via the
// `layout:` frontmatter key; otherwise props come through directly.
// @ts-expect-error frontmatter passthrough
const { title, description } = (Astro.props.frontmatter ?? Astro.props) as Props
const currentPath = Astro.url.pathname

// These globs run from *this* file, so the paths resolve against your own
// `src/pages` directory. The theme helpers turn them into nav data.
const pages = import.meta.glob('../pages/**/*.mdx', { eager: true })
const indexPages = import.meta.glob('../pages/*/index.mdx', { eager: true })

const sections = buildSidebarSections(pages)
const footerSections = buildFooterSections(indexPages)
---

<DocsLayout
  title={title}
  description={description}
  currentPath={currentPath}
  site={site}
  sections={sections}
  footerSections={footerSections}
>
  <slot />
</DocsLayout>
