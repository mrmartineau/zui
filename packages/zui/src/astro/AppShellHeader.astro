---
import type { HTMLAttributes } from 'astro/types'
import { appShellHeaderVariants } from '../shared/appShellVariants'

interface Props extends HTMLAttributes<'header'> {
  /** When true, auto-inject a sidebar-toggle button as the first child. Defaults to true. */
  toggle?: boolean
  /** Aria label for the auto-injected toggle. */
  toggleLabel?: string
  /** id of the sidebar element this header controls. Must match the AppShellSidebar id. */
  sidebarId?: string
  class?: string
}

const {
  toggle = true,
  toggleLabel = 'Toggle sidebar',
  sidebarId = 'zui-app-shell-sidebar',
  class: className,
  ...props
} = Astro.props

const classes = appShellHeaderVariants({ class: className })
---

<header class={classes} {...props}>
  {toggle && (
    <button
      type="button"
      class="zui-app-shell-toggle"
      data-zui-app-shell-toggle
      aria-label={toggleLabel}
      aria-controls={sidebarId}
    >
      <i class="ph ph-list" aria-hidden="true"></i>
    </button>
  )}
  <slot />
</header>

<script>
  // A single delegated listener instead of per-button bindings, so toggles
  // rendered after a view-transition navigation keep working without re-init.
  const TOGGLE_BOUND_KEY = '__zuiAppShellToggleBound'
  const globalWindow = window as typeof window & {
    [TOGGLE_BOUND_KEY]?: boolean
  }

  if (!globalWindow[TOGGLE_BOUND_KEY]) {
    document.addEventListener('click', (event) => {
      const btn = (event.target as Element | null)?.closest<HTMLButtonElement>(
        '[data-zui-app-shell-toggle]',
      )
      if (!btn) return
      const root = btn.closest<HTMLElement>('[data-zui-app-shell]')
      const controller = (
        root as unknown as {
          __zuiAppShellController?: { toggle: () => void }
        } | null
      )?.__zuiAppShellController
      controller?.toggle()
    })
    globalWindow[TOGGLE_BOUND_KEY] = true
  }
</script>
