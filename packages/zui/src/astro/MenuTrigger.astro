---
import type { HTMLAttributes } from 'astro/types'
import type { VariantProps } from 'cva'
import { buttonVariants } from '../shared/buttonVariants'

type ButtonVariantProps = VariantProps<typeof buttonVariants>

interface Props extends HTMLAttributes<'button'>, ButtonVariantProps {
  class?: string
  disabled?: boolean
}

const {
  class: className,
  disabled = false,
  variant = 'outline',
  color,
  size,
  shape,
  icon,
  ...props
} = Astro.props
const classes = buttonVariants({
  class: ['zui-menu-trigger', className].filter(Boolean).join(' '),
  color,
  icon,
  shape,
  size,
  variant,
})
---

<button
  aria-expanded="false"
  aria-haspopup="menu"
  class={classes}
  data-disabled={disabled ? 'true' : undefined}
  data-state="closed"
  data-zui-menu-trigger
  disabled={disabled}
  type="button"
  {...props}
>
  <slot />
</button>
