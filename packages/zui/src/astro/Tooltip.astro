---
import type { HTMLAttributes } from 'astro/types'
import type { VariantProps } from 'cva'
import { tooltipVariants } from '../shared/tooltipVariants'

type TooltipVariantProps = VariantProps<typeof tooltipVariants>

interface Props extends HTMLAttributes<'span'>, TooltipVariantProps {
  text: string
  class?: string
}

const { text, placement, class: className, ...props } = Astro.props

const id = `tooltip-${Math.random().toString(36).slice(2, 9)}`
const anchorName = `--${id}`
const contentClasses = [
  'zui-tooltip-content',
  tooltipVariants({ placement })
    .split(' ')
    .find((c) => c.startsWith('zui-tooltip-placement-')),
]
  .filter(Boolean)
  .join(' ')
---

<span class:list={['zui-tooltip', className]} {...props}>
  <span
    style={`anchor-name: ${anchorName}`}
    data-tooltip-trigger={id}
  >
    <slot />
  </span>
  <span
    popover="manual"
    id={id}
    class={contentClasses}
    role="tooltip"
    style={`position-anchor: ${anchorName}`}
  >{text}</span>
</span>

<script>
  const bound = new WeakSet<HTMLElement>()

  function initTooltips() {
    document.querySelectorAll<HTMLElement>('[data-tooltip-trigger]').forEach((trigger) => {
      if (bound.has(trigger)) return
      bound.add(trigger)
      const popover = document.getElementById(trigger.dataset.tooltipTrigger!)
      if (!popover) return
      trigger.addEventListener('mouseenter', () => popover.showPopover())
      trigger.addEventListener('mouseleave', () => popover.hidePopover())
      // focusin/focusout: native focus does not bubble, so focus events from
      // the wrapped child never reach this non-focusable span
      trigger.addEventListener('focusin', () => popover.showPopover())
      trigger.addEventListener('focusout', () => popover.hidePopover())
    })
  }

  // Bind immediately for plain MPA pages; astro:page-load only fires when
  // the site uses the <ClientRouter /> view-transitions router.
  initTooltips()
  document.addEventListener('astro:page-load', initTooltips)
</script>
