---
import type { HTMLAttributes } from 'astro/types'
import type { VariantProps } from 'cva'
import { buttonVariants } from '../shared/buttonVariants'

type ButtonVariantProps = VariantProps<typeof buttonVariants>

interface Props extends HTMLAttributes<'button'>, ButtonVariantProps {
  disabled?: boolean
  href?: string
  textValue?: string
  class?: string
}

const {
  href,
  class: className,
  disabled = false,
  textValue,
  variant = 'ghost',
  color,
  size,
  shape,
  icon,
  ...props
} = Astro.props
const classes = buttonVariants({
  class: ['zui-menu-item', className].filter(Boolean).join(' '),
  color,
  icon,
  shape,
  size,
  variant,
})
---

{
  href ? (
    <a
      aria-disabled={disabled ? 'true' : undefined}
      class={classes}
      data-disabled={disabled ? 'true' : undefined}
      data-state="closed"
      data-text-value={textValue}
      data-zui-menu-item
      href={href}
      role="menuitem"
      tabindex="-1"
      {...props}
    >
      <slot />
    </a>
  ) : (
    <button
      class={classes}
      data-disabled={disabled ? 'true' : undefined}
      data-state="closed"
      data-text-value={textValue}
      data-zui-menu-item
      disabled={disabled}
      role="menuitem"
      tabindex="-1"
      type="button"
      {...props}
    >
      <slot />
    </button>
  )
}
