---
import type { HTMLAttributes } from 'astro/types'
import type { VariantProps } from 'cva'
import { dialogVariants } from '../shared/dialogVariants'

type DialogVariantProps = VariantProps<typeof dialogVariants>

interface Props extends HTMLAttributes<'dialog'>, DialogVariantProps {
  id: string
  class?: string
  /** Controls how the dialog can be dismissed. Defaults to `"any"` (backdrop click or Esc). */
  closedby?: 'any' | 'closerequest' | 'none'
}

const { id, class: className, size, position, closedby = 'any', ...props } = Astro.props
const classes = dialogVariants({ size, position, class: className })
---

<dialog id={id} class={classes} closedby={closedby} {...props}>
  <slot />
</dialog>
