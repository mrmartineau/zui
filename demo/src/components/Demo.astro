---
import { Code } from 'astro:components'

interface Props {
  code: string
}

const { code } = Astro.props
---

<div class="demo">
  <div class="demo-preview">
    <slot />
  </div>
  <Code code={code.trim()} lang="html" theme="github-light" />
</div>

<style>
  .demo {
    margin-bottom: 1.5rem;
  }
  .demo-preview {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid #e4e4e7;
    border-radius: 0.5rem 0.5rem 0 0;
  }
  .demo :global(pre) {
    margin: 0;
    border-radius: 0 0 0.5rem 0.5rem;
    border: 1px solid #e4e4e7;
    border-top: none;
    font-size: 0.8125rem;
    padding: 1rem;
    overflow-x: auto;
  }
</style>
