---
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div class:list={['demo-preview', className]}>
  <slot />
</div>

<style>
  .demo-preview {
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-block: var(--space-sm);
  }
</style>
