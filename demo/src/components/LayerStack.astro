---
---

<div class="layer-stack">
  <div class="layer-card">
    <div class="layer-label">4</div>
    <div class="layer-content">
      <strong>zui.utilities</strong>
      <span>Typography classes, spacing helpers, layout utilities. Highest priority within ZUI.</span>
    </div>
  </div>
  <div class="layer-card">
    <div class="layer-label">3</div>
    <div class="layer-content">
      <strong>zui.components</strong>
      <span>Button, input, card, badge, and all other component styles.</span>
    </div>
  </div>
  <div class="layer-card">
    <div class="layer-label">2</div>
    <div class="layer-content">
      <strong>zui.base</strong>
      <span>Design tokens (colours, spacing, typography, shadows, radii), theme configuration, and base element styles.</span>
    </div>
  </div>
  <div class="layer-card">
    <div class="layer-label">1</div>
    <div class="layer-content">
      <strong>zui.reset</strong>
      <span>Minimal CSS reset — box-sizing, margin removal, media defaults. Lowest priority.</span>
    </div>
  </div>
</div>

<style>
  .layer-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    margin-block: var(--space-sm);
  }

  .layer-card {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .layer-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    font-weight: var(--font-weight-bold);
    width: 1.75rem;
    height: 1.75rem;
    display: grid;
    place-items: center;
    border-radius: var(--radius-full);
    flex-shrink: 0;
    background-color: var(--color-primary);
    color: var(--color-background);
  }

  .layer-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5xs);
  }

  .layer-content span {
    font-size: var(--step--1);
    color: color-mix(in oklch, var(--color-text) 70%, transparent);
  }
</style>
