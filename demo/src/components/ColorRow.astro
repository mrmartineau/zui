---
interface Shade {
  shade: number;
  value: string;
}

interface Props {
  name: string;
  shades: Shade[];
}

const { name, shades } = Astro.props;
---

<div class="color-row-wrapper">
  <p class="color-row__name">{name}</p>
  <div class="color-row__swatches">
    {shades.map(({ shade, value }) => (
      <div class="color-swatch" data-value={value}>
        <button
          type="button"
          class="color-swatch__btn"
          style={`background-color: var(--color-${name}-${shade})`}
          aria-label={`${name}-${shade}: ${value}`}
        />
        <span class="color-swatch__tooltip">{value}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .color-row-wrapper {
    display: contents;
  }

  .color-row__name {
    font-weight: 500;
    text-transform: capitalize;
    margin: 0;
    display: flex;
    align-items: center;
  }

  .color-row__swatches {
    display: grid;
    grid-template-columns: repeat(11, 1fr);
    gap: 0.375rem;
  }

  @media (min-width: 640px) {
    .color-row__swatches {
      gap: 1rem;
    }

    .color-row__name {
      padding-right: 3rem;
    }
  }

  .color-swatch {
    position: relative;
  }

  .color-swatch__btn {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 0.125rem;
    outline: 1px solid rgba(0, 0, 0, 0.1);
    outline-offset: -1px;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  @media (prefers-color-scheme: dark) {
    .color-swatch__btn {
      outline-color: rgba(255, 255, 255, 0.1);
    }
  }

  @media (min-width: 640px) {
    .color-swatch__btn {
      border-radius: 0.375rem;
    }
  }

  .color-swatch__btn:hover {
    transform: scale(1.1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    z-index: 1;
    position: relative;
  }

  .color-swatch__btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .color-swatch__tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: light-dark(#1e1e1e, #f5f5f5);
    color: light-dark(#f5f5f5, #1e1e1e);
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    white-space: nowrap;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
    z-index: 10;
  }

  .color-swatch:hover .color-swatch__tooltip {
    opacity: 1;
  }

  /* Copied feedback */
  .color-swatch--copied .color-swatch__btn::after {
    content: '✓';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    color: white;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .color-swatch--copied .color-swatch__btn {
    position: relative;
  }
</style>
