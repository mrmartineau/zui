---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
import CopyCode from '../../components/CopyCode.astro'
import TokenGrid from '../../components/TokenGrid.astro'
import TokenRow from '../../components/TokenRow.astro'

const spaces = [
  { token: '--space-5xs', label: '3→4px' },
  { token: '--space-4xs', label: '4→5px' },
  { token: '--space-3xs', label: '6→8px' },
  { token: '--space-2xs', label: '8→10px' },
  { token: '--space-xs', label: '12→15px' },
  { token: '--space-sm', label: '16→20px' },
  { token: '--space-md', label: '24→30px' },
  { token: '--space-lg', label: '32→40px' },
  { token: '--space-xl', label: '48→60px' },
  { token: '--space-2xl', label: '64→80px' },
  { token: '--space-3xl', label: '96→120px' },
]
---

<Layout title="Space">
  <h1>Space</h1>
  <p class="subtitle">A fluid spacing scale generated with <a href="https://utopia.fyi/space/calculator" class="zui-link">Utopia</a>. Values interpolate between 320px and 1350px viewport widths.</p>

  <section class="flow">
    <h2>Scale</h2>
    <TokenGrid columns={3}>
      {spaces.map(({ token, label }) => (
        <TokenRow>
          <CopyCode>{token}</CopyCode>
          <span class="label">{label}</span>
          <div class="bar" style={`width: var(${token}); min-width: 2px;`}></div>
        </TokenRow>
      ))}
    </TokenGrid>
  </section>

  <section class="flow">
    <h2>One-up pairs</h2>
    <p>Fluid pairs that transition between two adjacent steps for responsive spacing that grows faster.</p>
    <Code code={`--space-5xs-4xs   /* 3→5px */
--space-4xs-3xs   /* 4→8px */
--space-3xs-2xs   /* 6→10px */
--space-2xs-xs    /* 8→15px */
--space-xs-sm     /* 12→20px */
--space-sm-md     /* 16→30px */
--space-md-lg     /* 24→40px */
--space-lg-xl     /* 32→60px */
--space-xl-2xl    /* 48→80px */
--space-2xl-3xl   /* 64→120px */`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Usage</h2>
    <Code code={`.card {
  padding: var(--space-md);
  gap: var(--space-xs);
  margin-block-start: var(--space-lg-xl); /* fluid pair */
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }

  .label {
    font-size: var(--step--1);
    color: color-mix(in oklch, var(--color-text) 60%, transparent);
    min-width: 6rem;
    flex-shrink: 0;
  }

  .bar {
    height: var(--space-xs);
    background-color: var(--color-primary);
    border-radius: var(--radius-sm);
  }
</style>
