---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
import CopyCode from '../../components/CopyCode.astro'

const ratios = [
  { token: '--ratio-square', value: '1', label: '1:1' },
  { token: '--ratio-landscape', value: '4/3', label: '4:3' },
  { token: '--ratio-portrait', value: '3/4', label: '3:4' },
  { token: '--ratio-widescreen', value: '16/9', label: '16:9' },
  { token: '--ratio-ultrawide', value: '18/5', label: '18:5' },
  { token: '--ratio-golden', value: '1.618/1', label: 'φ' },
]
---

<Layout title="Aspect Ratio">
  <h1>Aspect Ratio</h1>
  <p class="subtitle">Predefined aspect ratio tokens for consistent media and container proportions.</p>

  <section class="flow">
    <h2>Ratios</h2>
    <div class="ratio-grid">
      {ratios.map(({ token, value, label }) => (
        <div class="ratio-card">
          <div class="ratio-preview" style={`aspect-ratio: var(${token});`}></div>
          <CopyCode>{token}</CopyCode>
          <span>{label} ({value})</span>
        </div>
      ))}
    </div>
  </section>

  <section class="flow">
    <h2>Usage</h2>
    <Code code={`.video-embed {
  aspect-ratio: var(--ratio-widescreen);
  width: 100%;
}

.avatar {
  aspect-ratio: var(--ratio-square);
  width: 3rem;
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }

  .ratio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-md);
    margin-block: var(--space-sm);
  }

  .ratio-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3xs);
    text-align: center;
  }

  .ratio-preview {
    width: 100%;
    max-width: 8rem;
    background-color: var(--color-primary);
    border-radius: var(--radius-md);
    opacity: 0.8;
  }

  .ratio-card span {
    font-size: var(--step--2);
    color: color-mix(in oklch, var(--color-text) 60%, transparent);
  }
</style>
