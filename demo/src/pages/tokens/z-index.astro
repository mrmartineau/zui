---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
import CopyCode from '../../components/CopyCode.astro'
import TokenGrid from '../../components/TokenGrid.astro'
import TokenRow from '../../components/TokenRow.astro'

const layers = [
  { token: '--z--1', value: '-1', desc: 'Behind everything' },
  { token: '--z-0', value: '0', desc: 'Default stacking' },
  { token: '--z-1', value: '1000', desc: 'Dropdowns, tooltips' },
  { token: '--z-2', value: '2000', desc: 'Sticky elements' },
  { token: '--z-3', value: '3000', desc: 'Fixed headers' },
  { token: '--z-4', value: '4000', desc: 'Overlays' },
  { token: '--z-5', value: '5000', desc: 'Modals' },
  { token: '--z-6', value: '6000', desc: 'Popovers' },
  { token: '--z-7', value: '7000', desc: 'Toasts' },
  { token: '--z-8', value: '8000', desc: 'Alerts' },
  { token: '--z-9', value: '9000', desc: 'Top-level UI' },
  { token: '--z-important', value: '2147483647', desc: 'Maximum (nuclear option)' },
]
---

<Layout title="Z-Index">
  <h1>Z-Index</h1>
  <p class="subtitle">A structured z-index scale with wide gaps between layers to avoid collisions.</p>

  <section class="flow">
    <h2>Scale</h2>
    <TokenGrid columns={3}>
      {layers.map(({ token, value, desc }) => (
        <TokenRow>
          <CopyCode>{token}</CopyCode>
          <span class="value">{value}</span>
          <span class="desc">{desc}</span>
        </TokenRow>
      ))}
    </TokenGrid>
  </section>

  <section class="flow">
    <h2>Usage</h2>
    <Code code={`.dropdown {
  z-index: var(--z-1);
}

.modal-backdrop {
  z-index: var(--z-4);
}

.modal {
  z-index: var(--z-5);
}

.toast {
  z-index: var(--z-7);
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }

  .value {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    min-width: 8rem;
    flex-shrink: 0;
  }

  .desc {
    font-size: var(--step--1);
    color: color-mix(in oklch, var(--color-text) 60%, transparent);
  }
</style>
