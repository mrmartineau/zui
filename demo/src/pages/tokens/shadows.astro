---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'

const shadows = [
  { token: '--shadow-sm', label: 'Small' },
  { token: '--shadow', label: 'Default' },
  { token: '--shadow-md', label: 'Medium' },
  { token: '--shadow-lg', label: 'Large' },
  { token: '--shadow-xl', label: 'Extra large' },
  { token: '--shadow-2xl', label: '2× large' },
]
---

<Layout title="Shadows">
  <h1>Shadows</h1>
  <p class="subtitle">Box shadow tokens using <code class="zui-code">oklch</code> relative colour syntax. The shadow colour is configurable via <code class="zui-code">--shadow-color</code>.</p>

  <section class="flow">
    <h2>Scale</h2>
    <div class="shadow-grid">
      {shadows.map(({ token, label }) => (
        <div class="shadow-card" style={`box-shadow: var(${token});`}>
          <code class="zui-code">{token}</code>
          <span>{label}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="flow">
    <h2>Customising shadow colour</h2>
    <p>Override <code class="zui-code">--shadow-color</code> in your theme to tint all shadows. It defaults to a neutral near-black (<code class="zui-code">oklch(0.2 0 0)</code>) and is overridden to <code class="zui-code">--color-sky-600</code> in the default theme.</p>

    <Code code={`:root {
  /* Neutral shadows */
  --shadow-color: oklch(0.2 0 0);

  /* Tinted shadows */
  --shadow-color: var(--color-indigo-600);
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Usage</h2>
    <Code code={`.card {
  box-shadow: var(--shadow-md);
}

.modal {
  box-shadow: var(--shadow-xl);
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }

  .shadow-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-md);
    margin-block: var(--space-sm);
  }

  .shadow-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    padding: var(--space-md);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface);
  }

  .shadow-card span {
    font-size: var(--step--1);
    color: color-mix(in oklch, var(--color-text) 65%, transparent);
  }
</style>
