---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
import CopyCode from '../../components/CopyCode.astro'

const radii = [
  { token: '--radius-sm', label: '3px' },
  { token: '--radius-md', label: '5px' },
  { token: '--radius-lg', label: '6px' },
  { token: '--radius-xl', label: '8px' },
  { token: '--radius-2xl', label: '12px' },
  { token: '--radius-3xl', label: '16px' },
  { token: '--radius-full', label: '9999px' },
  { token: '--radius-round', label: '50%' },
]
---

<Layout title="Radii">
  <h1>Radii</h1>
  <p class="subtitle">Border radius tokens scaled by <code class="zui-code">--radius-scale</code> for global roundness control.</p>

  <section class="flow">
    <h2>Scale</h2>
    <div class="radii-grid">
      {radii.map(({ token, label }) => (
        <div class="radii-card">
          <div class="radii-preview" style={`border-radius: var(${token});`}></div>
          <CopyCode>{token}</CopyCode>
          <span>{label} × scale</span>
        </div>
      ))}
    </div>
  </section>

  <section class="flow">
    <h2>Scaling</h2>
    <p>All radii (except <code class="zui-code">--radius-round</code>) are multiplied by <code class="zui-code">--radius-scale</code>. Change this single value to globally adjust roundness.</p>
    <Code code={`:root {
  --radius-scale: 1;   /* default */
  --radius-scale: 0;   /* sharp corners */
  --radius-scale: 2;   /* extra round */
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Usage</h2>
    <Code code={`.card {
  border-radius: var(--radius-xl);
}

.avatar {
  border-radius: var(--radius-round);
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }

  .radii-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-md);
    margin-block: var(--space-sm);
  }

  .radii-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3xs);
    text-align: center;
  }

  .radii-preview {
    width: 5rem;
    height: 5rem;
    background-color: var(--color-primary);
  }

  .radii-card span {
    font-size: var(--step--2);
    color: color-mix(in oklch, var(--color-text) 60%, transparent);
  }
</style>
