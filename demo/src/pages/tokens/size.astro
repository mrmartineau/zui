---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
import CopyCode from '../../components/CopyCode.astro'
import TokenGrid from '../../components/TokenGrid.astro'
import TokenRow from '../../components/TokenRow.astro'
---

<Layout title="Size">
  <h1>Size</h1>
  <p class="subtitle">Semantic size tokens for widths, heights, and responsive viewport units.</p>

  <section class="flow">
    <h2>Fractions</h2>
    <TokenGrid columns={3}>
      <TokenRow>
        <CopyCode>--size-quarter</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 25%;"></div>
        </div>
        <span>25%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-third</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 33.333%;"></div>
        </div>
        <span>33.3%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-half</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 50%;"></div>
        </div>
        <span>50%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-twothirds</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 66.666%;"></div>
        </div>
        <span>66.7%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-threequarters</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 75%;"></div>
        </div>
        <span>75%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-full</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 100%;"></div>
        </div>
        <span>100%</span>
      </TokenRow>
    </TokenGrid>

    <h3>Fifths</h3>
    <TokenGrid columns={3}>
      <TokenRow>
        <CopyCode>--size-fifth</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 20%;"></div>
        </div>
        <span>20%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-twofifths</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 40%;"></div>
        </div>
        <span>40%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-threefifths</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 60%;"></div>
        </div>
        <span>60%</span>
      </TokenRow>
      <TokenRow>
        <CopyCode>--size-fourfifths</CopyCode>
        <div class="bar-wrapper">
          <div class="bar" style="width: 80%;"></div>
        </div>
        <span>80%</span>
      </TokenRow>
    </TokenGrid>
  </section>

  <section class="flow">
    <h2>Viewport units</h2>
    <Code code={`--size-svw: 100svw;   --size-svh: 100svh;
--size-lvw: 100lvw;   --size-lvh: 100lvh;
--size-dvw: 100dvw;   --size-dvh: 100dvh;`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Intrinsic sizing</h2>
    <Code code={`--size-min: min-content;
--size-max: max-content;
--size-fit: fit-content;`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Usage</h2>
    <Code code={`.sidebar {
  width: var(--size-quarter);
}

.hero {
  min-height: var(--size-dvh);
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }

  :global(.token-row) > span {
    min-width: 4rem;
    text-align: right;
  }

  .bar-wrapper {
    flex-grow: 1;
  }

  .bar {
    height: var(--space-xs);
    background-color: var(--color-primary);
    border-radius: var(--radius-sm);
    max-width: 100%;
  }
</style>
