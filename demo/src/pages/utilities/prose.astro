---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
import TokenGrid from '../../components/TokenGrid.astro'
import TokenRow from '../../components/TokenRow.astro'
import CopyCode from '../../components/CopyCode.astro'
---

<Layout title="Prose">
  <h1>Prose</h1>
  <p class="subtitle">Rich text styling for long-form content. Applies typography, spacing, and element styles to any container.</p>

  <section class="flow">
    <h2>Usage</h2>
    <p>Wrap any block of HTML content with <code class="zui-code">.prose</code> to get styled headings, paragraphs, lists, blockquotes, links, code blocks, and media.</p>
    <Code code={`<article class="prose">
  <h1>Article Title</h1>
  <p>Body text with <a href="#">links</a> and <code>inline code</code>.</p>
  <ul>
    <li>List items</li>
    <li>Are styled automatically</li>
  </ul>
  <blockquote>Blockquotes get a left border.</blockquote>
</article>`} lang="html" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>What it styles</h2>
    <ul class="feature-list">
      <li><strong>Headings</strong> — h1–h4 with type scale, heading font family, and balanced text wrapping</li>
      <li><strong>Flow spacing</strong> — automatic vertical rhythm via <code class="zui-code">--flow-space</code></li>
      <li><strong>Links</strong> — accent-coloured with underline decoration and hover transitions</li>
      <li><strong>Lists</strong> — nested list style types (disc → circle → square for ul; decimal → lower-roman → lower-alpha for ol)</li>
      <li><strong>Blockquotes</strong> — left border with italic styling</li>
      <li><strong>Code</strong> — inline <code class="zui-code">code</code> and <code class="zui-code">pre</code> blocks with monospace font and background</li>
      <li><strong>Media</strong> — images, iframes, and videos get border-radius and a subtle border</li>
      <li><strong>Horizontal rules</strong> — styled as a thin background-colour line</li>
    </ul>
  </section>

  <section class="flow">
    <h2>Custom properties</h2>
    <Code code={`.prose {
  --prose-color: var(--text-color);
  --prose-accent-color: var(--accent-9);
  --prose-link-color: var(--accent-11);
  --prose-link-color-decoration: var(--accent-7);
  --prose-link-color-decoration-hover: var(--accent-8);
  --prose-code-color: var(--violet-11);
  --prose-code-bg-color: var(--violet-3);
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Modifiers</h2>
    <TokenGrid>
      <TokenRow><CopyCode>.prose.inverted</CopyCode><span>Inverted colour scheme for dark backgrounds</span></TokenRow>
      <TokenRow><CopyCode>.prose.max-width-p</CopyCode><span>Limits paragraph width to 65ch for readability</span></TokenRow>
    </TokenGrid>
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding-inline-start: var(--space-md);
  }

  .feature-list li {
    line-height: var(--line-height-md);
  }
</style>
