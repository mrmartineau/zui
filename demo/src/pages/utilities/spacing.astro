---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
import TokenGrid from '../../components/TokenGrid.astro'
import TokenRow from '../../components/TokenRow.astro'
import CopyCode from '../../components/CopyCode.astro'

const side = `{side}`
const size = `{size}`
---

<Layout title="Spacing">
  <h1>Spacing</h1>
  <p class="subtitle">Margin, padding, and gap utility classes mapped to the fluid space scale.</p>

  <section class="flow">
    <h2>Margin</h2>
    <p>Classes follow the pattern <code class="zui-code">.m{side}-{size}</code> where side is optional (<code class="zui-code">x</code>, <code class="zui-code">y</code>, <code class="zui-code">t</code>, <code class="zui-code">r</code>, <code class="zui-code">b</code>, <code class="zui-code">l</code>) and size comes from the space scale.</p>

    <TokenGrid>
      <TokenRow header>
        <span>Class</span>
        <span>Property</span>
      </TokenRow>
      <TokenRow><CopyCode>{`.m-{size}`}</CopyCode><span>margin</span></TokenRow>
      <TokenRow><CopyCode>{`.mx-{size}`}</CopyCode><span>margin-inline</span></TokenRow>
      <TokenRow><CopyCode>{`.my-{size}`}</CopyCode><span>margin-block</span></TokenRow>
      <TokenRow><CopyCode>{`.mt-{size}`}</CopyCode><span>margin-block-start</span></TokenRow>
      <TokenRow><CopyCode>{`.mr-{size}`}</CopyCode><span>margin-inline-end</span></TokenRow>
      <TokenRow><CopyCode>{`.mb-{size}`}</CopyCode><span>margin-block-end</span></TokenRow>
      <TokenRow><CopyCode>{`.ml-{size}`}</CopyCode><span>margin-inline-start</span></TokenRow>
    </TokenGrid>

    <h3>Available sizes</h3>
    <p><code class="zui-code">0</code>, <code class="zui-code">auto</code>, <code class="zui-code">2xs</code>, <code class="zui-code">xs</code>, <code class="zui-code">s</code>, <code class="zui-code">m</code>, <code class="zui-code">l</code>, <code class="zui-code">xl</code>, <code class="zui-code">2xl</code>, <code class="zui-code">3xl</code>, <code class="zui-code">4xl</code></p>

    <Code code={`<div class="mt-xl mb-m mx-auto">Centred with vertical spacing</div>`} lang="html" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Padding</h2>
    <p>Same pattern as margin: <code class="zui-code">.p{side}-{size}</code>.</p>

    <TokenGrid>
      <TokenRow header>
        <span>Class</span>
        <span>Property</span>
      </TokenRow>
      <TokenRow><CopyCode>{`.p-{size}`}</CopyCode><span>padding</span></TokenRow>
      <TokenRow><CopyCode>{`.px-{size}`}</CopyCode><span>padding-inline</span></TokenRow>
      <TokenRow><CopyCode>{`.py-{size}`}</CopyCode><span>padding-block</span></TokenRow>
      <TokenRow><CopyCode>{`.pt-{size}`}</CopyCode><span>padding-block-start</span></TokenRow>
      <TokenRow><CopyCode>{`.pr-{size}`}</CopyCode><span>padding-inline-end</span></TokenRow>
      <TokenRow><CopyCode>{`.pb-{size}`}</CopyCode><span>padding-block-end</span></TokenRow>
      <TokenRow><CopyCode>{`.pl-{size}`}</CopyCode><span>padding-inline-start</span></TokenRow>
    </TokenGrid>

    <Code code={`<section class="px-m py-xl">Horizontal and vertical padding</section>`} lang="html" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Gap</h2>
    <p>Gap utilities for flex and grid containers: <code class="zui-code">.gap-{size}</code>, <code class="zui-code">.gapx-{size}</code> (column-gap), <code class="zui-code">.gapy-{size}</code> (row-gap).</p>

    <TokenGrid>
      <TokenRow header>
        <span>Class</span>
        <span>Property</span>
      </TokenRow>
      <TokenRow><CopyCode>{`.gap-{size}`}</CopyCode><span>gap</span></TokenRow>
      <TokenRow><CopyCode>{`.gapx-{size}`}</CopyCode><span>column-gap</span></TokenRow>
      <TokenRow><CopyCode>{`.gapy-{size}`}</CopyCode><span>row-gap</span></TokenRow>
    </TokenGrid>

    <h3>Available sizes</h3>
    <p><code class="zui-code">0</code>, <code class="zui-code">2xs</code>, <code class="zui-code">xs</code>, <code class="zui-code">s</code>, <code class="zui-code">m</code>, <code class="zui-code">l</code>, <code class="zui-code">xl</code>, <code class="zui-code">2xl</code>, <code class="zui-code">3xl</code>, <code class="zui-code">4xl</code></p>

    <Code code={`<div class="flex flex-wrap gap-m">
  <div>Item 1</div>
  <div>Item 2</div>
  <div>Item 3</div>
</div>`} lang="html" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }
</style>
