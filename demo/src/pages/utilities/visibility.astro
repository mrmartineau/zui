---
import Layout from '../../layouts/Layout.astro'
import { Code } from 'astro:components'
---

<Layout title="Visibility">
  <h1>Visibility</h1>
  <p class="subtitle">Utility classes for hiding content visually while keeping it accessible to screen readers.</p>

  <section class="flow">
    <h2>Screen reader only</h2>
    <p>The <code class="zui-code">.sr-only</code> (aliased as <code class="zui-code">.visually-hidden</code>) class hides an element visually but keeps it in the accessibility tree for screen readers.</p>

    <Code code={`.sr-only,
.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}`} lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>

  <section class="flow">
    <h2>Usage</h2>
    <Code code={`<!-- Label for icon-only button -->
<button class="zui-button zui-button-icon">
  <i class="ph ph-gear"></i>
  <span class="sr-only">Settings</span>
</button>

<!-- Skip navigation link -->
<a href="#main" class="sr-only">Skip to main content</a>`} lang="html" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
  </section>
</Layout>

<style>
  .subtitle {
    font-size: var(--step-1);
    color: var(--color-text);
    max-width: 55ch;
  }

  section {
    margin-block-start: var(--space-xl);
  }
</style>
