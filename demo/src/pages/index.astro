---
import Layout from '../layouts/Layout.astro'
import { Code } from 'astro:components'
---

<Layout title="Home">
    <h1>ZUI</h1>
    <p class="subtitle">A CSS UI library with optional React and Astro components.</p>

    <div class="grid">
        <div class="card">
            <h2>CSS-first</h2>
            <p>Built on standard CSS with <code>@layer</code> for clean cascade control and custom properties for full configurability. No build step required&mdash;just import and go.</p>
        </div>

        <div class="card">
            <h2>Framework components</h2>
            <p>Use the plain CSS classes anywhere, or reach for ready-made React and Astro component wrappers that map props to the underlying class API.</p>
        </div>

        <div class="card">
            <h2>Themeable</h2>
            <p>Override semantic colours, fonts, and radii through <code>theme.css</code> custom properties. Supports <code>light-dark()</code> colour schemes out of the box.</p>
        </div>

        <div class="card">
            <h2>Design tokens</h2>
            <p>A comprehensive token system covering colours, spacing, typography, shadows, radii, easing, and z-index&mdash;all exposed as CSS custom properties.</p>
        </div>
    </div>

    <section class="flow">
        <h2>Quick start</h2>

        <p>Install the package:</p>
        <Code code="npm install @mrmartineau/zui" lang="bash" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />

        <p>Import the CSS in your project:</p>
        <Code code="@import '@mrmartineau/zui/css';" lang="css" themes={{ light: 'rose-pine-dawn', dark: 'rose-pine' }} />
    </section>

    <nav class="links">
        <a href="/installation" class="zui-button">Installation</a>
        <a href="/components/button" class="zui-button zui-button-variant-outline">Components</a>
    </nav>
</Layout>

<style>
    .subtitle {
        font-size: var(--font-size-lg);
        color: var(--color-text);
        max-width: 48ch;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
        gap: var(--space-md);
        margin-block-start: var(--space-lg);
    }

    .card {
        padding: var(--space-md);
        border: 1px var(--border-style) var(--color-border);
        border-radius: calc(var(--radius-md) * var(--radius-scale));
    }

    .card h2 {
        margin-block-end: var(--space-xs);
    }

    .card p {
        color: var(--color-text);
    }

    section {
        margin-block-start: var(--space-xl);
    }

    .links {
        display: flex;
        gap: var(--space-sm);
        margin-block-start: var(--space-xl);
    }
</style>
